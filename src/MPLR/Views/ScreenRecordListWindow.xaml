<ui:FluentWindow x:Class="MPLR.Views.ScreenRecordListWindow"
                 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                 xmlns:local="clr-namespace:MPLR.Views"
                 xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                 xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
                 x:Name="Root"
                 Title="{I18N ToolbarScreenRecordList}"
                 d:Background="#FF101010"
                 ExtendsContentIntoTitleBar="True"
                 WindowBackdropType="Mica"
                 WindowStartupLocation="Manual"
                 mc:Ignorable="d">
    <ui:FluentWindow.Resources>
        <SolidColorBrush x:Key="VideoListAccentHoverBrush" Color="#003C6A" />
        <SolidColorBrush x:Key="VideoListAccentPressedBrush" Color="#002E52" />
        <Style x:Key="VideoListToolbarButtonStyle" TargetType="{x:Type Button}" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="MinWidth" Value="82" />
            <Setter Property="Height" Value="34" />
            <Setter Property="Padding" Value="12,0" />
        </Style>
        <Style x:Key="VideoListIconButtonStyle" TargetType="{x:Type Button}" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Width" Value="34" />
            <Setter Property="Height" Value="34" />
            <Setter Property="MinWidth" Value="34" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
        </Style>
        <Style x:Key="VideoListAccentButtonStyle" TargetType="{x:Type Button}" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Background" Value="{DynamicResource SystemAccentColorPrimaryBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource SystemAccentColorPrimaryBrush}" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Button}">
                        <Border x:Name="RootBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                              Margin="{TemplateBinding Padding}"
                                              RecognizesAccessKey="True"
                                              TextElement.Foreground="{TemplateBinding Foreground}" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="RootBorder" Property="Background" Value="{StaticResource VideoListAccentHoverBrush}" />
                                <Setter TargetName="RootBorder" Property="BorderBrush" Value="{StaticResource VideoListAccentHoverBrush}" />
                                <Setter Property="Foreground" Value="White" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="RootBorder" Property="Background" Value="{StaticResource VideoListAccentPressedBrush}" />
                                <Setter TargetName="RootBorder" Property="BorderBrush" Value="{StaticResource VideoListAccentPressedBrush}" />
                                <Setter Property="Foreground" Value="White" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="RootBorder" Property="Opacity" Value="0.45" />
                                <Setter Property="Foreground" Value="White" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="VideoListAccentIconButtonStyle" TargetType="{x:Type Button}" BasedOn="{StaticResource VideoListAccentButtonStyle}">
            <Setter Property="Width" Value="34" />
            <Setter Property="Height" Value="34" />
            <Setter Property="MinWidth" Value="34" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
        </Style>
        <Style x:Key="VideoListAccentToolbarButtonStyle" TargetType="{x:Type Button}" BasedOn="{StaticResource VideoListAccentButtonStyle}">
            <Setter Property="MinWidth" Value="82" />
            <Setter Property="Height" Value="34" />
            <Setter Property="Padding" Value="12,0" />
        </Style>
        <Style x:Key="VideoMetaChipStyle" TargetType="{x:Type Border}">
            <Setter Property="MinHeight" Value="24" />
            <Setter Property="Padding" Value="10,3" />
            <Setter Property="Margin" Value="0,0,8,0" />
            <Setter Property="CornerRadius" Value="7" />
            <Setter Property="Background" Value="#18337DFF" />
            <Setter Property="BorderBrush" Value="#30337DFF" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>
        <Style x:Key="VideoMetaChipTextStyle" TargetType="{x:Type TextBlock}">
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Foreground" Value="{DynamicResource TextFillColorSecondaryBrush}" />
            <Setter Property="TextTrimming" Value="CharacterEllipsis" />
        </Style>
    </ui:FluentWindow.Resources>

    <Grid>
        <Grid Margin="14,48,14,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="48" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Grid Grid.Row="0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <ui:StackPanel Grid.Column="0"
                               HorizontalAlignment="Left"
                               VerticalAlignment="Center"
                               Orientation="Horizontal"
                               Spacing="8">
                    <Button Click="RefreshClick"
                            Style="{StaticResource VideoListToolbarButtonStyle}">
                        <ui:StackPanel Orientation="Horizontal" Spacing="7">
                            <ui:FontIcon FontFamily="{DynamicResource SymbolThemeFontFamily}"
                                         Glyph="{x:Static ui:FontSymbols.Sync}" />
                            <TextBlock Text="刷新" />
                        </ui:StackPanel>
                    </Button>
                    <Button Click="ToggleSortClick"
                            Style="{StaticResource VideoListToolbarButtonStyle}">
                        <ui:StackPanel Orientation="Horizontal" Spacing="7">
                            <ui:FontIcon FontFamily="{DynamicResource SymbolThemeFontFamily}">
                                <ui:FontIcon.Style>
                                    <Style TargetType="{x:Type ui:FontIcon}">
                                        <Setter Property="Glyph" Value="{x:Static ui:FontSymbols.ChevronUp}" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsSortDescending}" Value="True">
                                                <Setter Property="Glyph" Value="{x:Static ui:FontSymbols.ChevronDown}" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </ui:FontIcon.Style>
                            </ui:FontIcon>
                            <TextBlock Text="{Binding SortDirectionText}" />
                        </ui:StackPanel>
                    </Button>
                    <Button Click="ImportFolderClick"
                            Style="{StaticResource VideoListToolbarButtonStyle}">
                        <ui:StackPanel Orientation="Horizontal" Spacing="7">
                            <ui:FontIcon FontFamily="{DynamicResource SymbolThemeFontFamily}"
                                         Glyph="{x:Static ui:FontSymbols.FolderOpen}" />
                            <TextBlock Text="导入" />
                        </ui:StackPanel>
                    </Button>
                </ui:StackPanel>

                <ui:StackPanel Grid.Column="2"
                               HorizontalAlignment="Right"
                               VerticalAlignment="Center"
                               Orientation="Horizontal"
                               Spacing="8">
                    <ui:StackPanel Orientation="Horizontal"
                                   Spacing="8"
                                   HorizontalAlignment="Right">
                        <ui:StackPanel.Style>
                            <Style TargetType="{x:Type ui:StackPanel}">
                                <Setter Property="Visibility" Value="Collapsed" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsMultiSelectMode}" Value="True">
                                        <Setter Property="Visibility" Value="Visible" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </ui:StackPanel.Style>
                        <TextBlock VerticalAlignment="Center"
                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                   Text="{Binding SelectedVideoSummary}" />
                        <Button Click="DeleteSelectedClick"
                                IsEnabled="{Binding HasSelectedVideos}"
                                Style="{StaticResource VideoListAccentIconButtonStyle}"
                                ToolTip="删除">
                            <ui:FontIcon FontFamily="{DynamicResource SymbolThemeFontFamily}"
                                         Glyph="{x:Static ui:FontSymbols.Delete}" />
                        </Button>
                        <Button Click="MoveSelectedClick"
                                IsEnabled="{Binding HasSelectedVideos}"
                                Style="{StaticResource VideoListAccentIconButtonStyle}"
                                ToolTip="移动">
                            <ui:FontIcon FontFamily="{DynamicResource SymbolThemeFontFamily}"
                                         Glyph="{x:Static ui:FontSymbols.FolderOpen}" />
                        </Button>
                        <Button Click="CopySelectedClick"
                                IsEnabled="{Binding HasSelectedVideos}"
                                Style="{StaticResource VideoListAccentIconButtonStyle}"
                                ToolTip="复制">
                            <ui:FontIcon FontFamily="{DynamicResource SymbolThemeFontFamily}"
                                         Glyph="{x:Static ui:FontSymbols.Copy}" />
                        </Button>
                        <Button Click="CancelMultiSelectClick"
                                Style="{StaticResource VideoListAccentIconButtonStyle}"
                                ToolTip="取消">
                            <ui:FontIcon FontFamily="{DynamicResource SymbolThemeFontFamily}"
                                         Glyph="{x:Static ui:FontSymbols.CalculatorMultiply}" />
                        </Button>
                    </ui:StackPanel>
                    <Button Click="ToggleMultiSelectClick">
                        <Button.Style>
                            <Style TargetType="{x:Type Button}" BasedOn="{StaticResource VideoListAccentToolbarButtonStyle}">
                                <Setter Property="Visibility" Value="Visible" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsMultiSelectMode}" Value="True">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                        <ui:StackPanel Orientation="Horizontal" Spacing="7">
                            <ui:FontIcon FontFamily="{DynamicResource SymbolThemeFontFamily}"
                                         Glyph="{x:Static ui:FontSymbols.Accept}" />
                            <TextBlock Text="多选" />
                        </ui:StackPanel>
                    </Button>
                </ui:StackPanel>
            </Grid>

            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                <ItemsControl ItemsSource="{Binding Videos}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Margin="2,8,10,0"
                                    Padding="14"
                                    Background="{DynamicResource CardBackground}"
                                    BorderBrush="{DynamicResource CardBorderBrush}"
                                    BorderThickness="1"
                                    CornerRadius="10">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="172" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>

                                    <Border Width="148"
                                            Height="111"
                                            HorizontalAlignment="Left"
                                            VerticalAlignment="Top"
                                            Background="#16000000"
                                            BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
                                            BorderThickness="1"
                                            CornerRadius="8"
                                            ClipToBounds="True">
                                        <Grid>
                                            <Border CornerRadius="8">
                                                <Border.Background>
                                                    <ImageBrush AlignmentX="Right"
                                                                AlignmentY="Top"
                                                                ImageSource="{Binding ThumbnailPath}"
                                                                Stretch="UniformToFill" />
                                                </Border.Background>
                                            </Border>
                                            <ui:FontIcon HorizontalAlignment="Center"
                                                         VerticalAlignment="Center"
                                                         FontFamily="{DynamicResource SymbolThemeFontFamily}"
                                                         FontSize="24"
                                                         Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                                         Glyph="{x:Static ui:FontSymbols.Video}">
                                                <ui:FontIcon.Style>
                                                    <Style TargetType="{x:Type ui:FontIcon}">
                                                        <Setter Property="Visibility" Value="Visible" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding HasThumbnail}" Value="True">
                                                                <Setter Property="Visibility" Value="Collapsed" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </ui:FontIcon.Style>
                                            </ui:FontIcon>
                                        </Grid>
                                    </Border>

                                    <StackPanel Grid.Column="1" Margin="0,0,20,0">
                                        <TextBlock FontSize="18"
                                                   FontWeight="SemiBold"
                                                   Text="{Binding FileName}"
                                                   TextTrimming="CharacterEllipsis" />
                                        <ui:StackPanel Margin="0,10,0,0"
                                                       Orientation="Horizontal"
                                                       Spacing="0">
                                            <Border MaxWidth="220" Style="{StaticResource VideoMetaChipStyle}">
                                                <TextBlock Style="{StaticResource VideoMetaChipTextStyle}"
                                                           Text="{Binding NickName}" />
                                            </Border>
                                            <Border MaxWidth="160" Style="{StaticResource VideoMetaChipStyle}">
                                                <TextBlock Style="{StaticResource VideoMetaChipTextStyle}"
                                                           Text="{Binding Resolution}" />
                                            </Border>
                                            <Border MaxWidth="150" Style="{StaticResource VideoMetaChipStyle}">
                                                <TextBlock Style="{StaticResource VideoMetaChipTextStyle}"
                                                           Text="{Binding Bitrate}" />
                                            </Border>
                                        </ui:StackPanel>
                                        <TextBlock Margin="0,10,0,0"
                                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                                   Text="{Binding Title}"
                                                   TextTrimming="CharacterEllipsis" />
                                    </StackPanel>

                                    <StackPanel Grid.Column="2"
                                                HorizontalAlignment="Right"
                                                VerticalAlignment="Center"
                                                Orientation="Horizontal">
                                        <Button Margin="0,0,8,0"
                                                Click="OpenVideoClick"
                                                Content="打开视频"
                                                Tag="{Binding}" />
                                        <Button Margin="0,0,8,0"
                                                Click="TranscodeVideoClick"
                                                Content="转码"
                                                Tag="{Binding}">
                                            <Button.Style>
                                                <Style TargetType="{x:Type Button}" BasedOn="{StaticResource {x:Type Button}}">
                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding CanTranscode}" Value="True">
                                                            <Setter Property="Visibility" Value="Visible" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Button.Style>
                                        </Button>
                                        <Button Click="OpenDirectoryClick"
                                                Content="打开目录"
                                                Tag="{Binding}" />
                                    </StackPanel>

                                    <CheckBox Grid.Column="3"
                                              Margin="14,0,0,0"
                                              HorizontalAlignment="Right"
                                              VerticalAlignment="Center"
                                              Click="SelectionCheckBoxClick"
                                              IsChecked="{Binding IsSelected, Mode=TwoWay}"
                                              Tag="{Binding}">
                                        <CheckBox.Style>
                                            <Style TargetType="{x:Type CheckBox}" BasedOn="{StaticResource {x:Type CheckBox}}">
                                                <Setter Property="Visibility" Value="Collapsed" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding DataContext.IsMultiSelectMode, RelativeSource={RelativeSource AncestorType={x:Type local:ScreenRecordListWindow}}}" Value="True">
                                                        <Setter Property="Visibility" Value="Visible" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </CheckBox.Style>
                                    </CheckBox>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Grid>

        <Grid>
            <ui:TitleBar Title="{I18N ToolbarScreenRecordList}" ShowMaximize="False">
                <ui:TitleBar.Icon>
                    <ui:SymbolIcon Symbol="Video24" />
                </ui:TitleBar.Icon>
            </ui:TitleBar>
        </Grid>
    </Grid>
</ui:FluentWindow>
