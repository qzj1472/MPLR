                                            Text="{Binding ProxyUrl, Mode=TwoWay}" />
                                <Button Grid.Column="2"
                                        Margin="8,0,0,0"
                                        Command="{Binding CheckProxyUrlCommand}"
                                        Content="{I18N CheckConnectivity}" />
                            </ui:Grid>
                        </ui:StackPanel>
                    </ui:CardExpander>
                    <ui:CardExpander>
                        <ui:CardExpander.Header>
                            <ui:Grid ColumnDefinitions="Auto,*,Auto">
                                <Grid Grid.Column="0" Margin="0,0,12,0">
                                    <TextBlock MinWidth="26"
                                               Margin="4,0,0,0"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"
                                               FontFamily="{DynamicResource SymbolThemeFontFamily}"
                                               FontSize="18"
                                               Text="{x:Static ui:FontSymbols.Rename}" />
                                </Grid>
                                <ui:Grid Grid.Column="1" RowDefinitions="Auto,Auto">
                                    <TextBlock Grid.Row="0" Text="{I18N UseCookie}" />
                                    <TextBlock Grid.Row="1"
                                               FontSize="11"
                                               Foreground="{DynamicResource SystemFillColorSolidNeutralBrush}"
                                               Text="{I18N UseCookieHint}" />
                                </ui:Grid>
                                <Grid Grid.Column="2" Margin="0,0,12,0">
                                    <!--  EMPTY  -->
                                </Grid>
                            </ui:Grid>
                        </ui:CardExpander.Header>
                        <ui:StackPanel Spacing="12">
                            <ItemsControl Margin="42,0,28,0" ItemsSource="{Binding PlatformCookieItems}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <ui:Grid Margin="0,0,0,8" ColumnDefinitions="Auto,*,Auto">
                                            <TextBlock Grid.Column="0"
                                                       MinWidth="140"
                                                       VerticalAlignment="Center"
                                                       Text="{Binding DisplayName}" />
                                            <ui:TextBox Grid.Column="1"
                                                        Margin="8,0,0,0"
                                                        PlaceholderText="{I18N UseCookieEnterHint}"
                                                        Text="{Binding Cookie, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                            <Button Grid.Column="2"
                                                    Margin="8,0,0,0"
                                                    Command="{Binding DataContext.OpenHowToGetCookieChinaCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                    Content="{I18N HowToGet}" />
                                        </ui:Grid>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ui:StackPanel>
                    </ui:CardExpander>
                    <ui:CardExpander>
                        <ui:CardExpander.Header>
                            <ui:Grid ColumnDefinitions="Auto,*,Auto">
                                <Grid Grid.Column="0" Margin="0,0,12,0">
                                    <TextBlock MinWidth="26"
                                               Margin="4,0,0,0"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"
                                               FontFamily="{DynamicResource SymbolThemeFontFamily}"
                                               FontSize="18"
                                               Text="{x:Static ui:FontSymbols.EaseOfAccess}" />
                                </Grid>
                                <ui:Grid Grid.Column="1" RowDefinitions="Auto,Auto">
                                    <TextBlock Grid.Row="0" Text="{I18N UserAgent}" />
                                    <TextBlock Grid.Row="1"
                                               FontSize="11"
                                               Foreground="{DynamicResource SystemFillColorSolidNeutralBrush}"
                                               Text="{I18N UserAgentHint}" />
                                </ui:Grid>
                                <Grid Grid.Column="2" Margin="0,0,12,0">
                                    <!--  EMPTY  -->
                                </Grid>
                            </ui:Grid>
                        </ui:CardExpander.Header>
                        <ui:StackPanel Spacing="12">
                            <ui:Grid Margin="42,0,28,0" ColumnDefinitions="Auto,*">
                                <TextBlock VerticalAlignment="Center" Text="{I18N UserAgent}" />
                                <ui:TextBox Grid.Column="1"
                                            Margin="8,0,0,0"
                                            PlaceholderText="{I18N UserAgentEnterHint}"
                                            Text="{Binding UserAgent, Mode=TwoWay}" />
                            </ui:Grid>
                        </ui:StackPanel>
                    </ui:CardExpander>
                    <FrameworkElement Height="10" />
                </ui:StackPanel>
            </ScrollViewer>
        </ui:Grid>
        <Grid>
            <ui:TitleBar Title="{I18N Settings}" ShowMaximize="False">
                <ui:TitleBar.Icon>
                    <ui:ImageIcon Source="pack://application:,,,/Assets/Favicon.png" />
                </ui:TitleBar.Icon>
            </ui:TitleBar>
        </Grid>
    </Grid>
</ui:FluentWindow>

