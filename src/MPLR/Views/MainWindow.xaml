<ui:FluentWindow x:Class="MPLR.Views.MainWindow"
                 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:animations="clr-namespace:Wpf.Ui.Animations;assembly=Wpf.Ui"
                 xmlns:b="http://schemas.github.com/computedbehaviors/2024/xaml"
                 xmlns:c="http://schemas.github.com/computedconverters/2024/xaml"
                 xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                 xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
                 xmlns:local="clr-namespace:MPLR"
                 xmlns:lottie="clr-namespace:LottieSharp.WPF;assembly=LottieSharp"
                 xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                 xmlns:sys="clr-namespace:System;assembly=System.Runtime"
                 xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
                 xmlns:vio="http://schemas.lepo.co/wpfui/2022/xaml/violeta"
                 xmlns:views="clr-namespace:MPLR.Views"
                 x:Name="Root"
                 Title="{I18N Title}"
                 d:Background="#FF101010"
                 ExtendsContentIntoTitleBar="True"
                 WindowBackdropType="Mica"
                 WindowStartupLocation="Manual"
                 mc:Ignorable="d">
    <ui:FluentWindow.Resources>
        <SolidColorBrush x:Key="MainAccentHoverBrush" Color="#003C6A" />
        <SolidColorBrush x:Key="MainAccentPressedBrush" Color="#003C6A" />
        <SolidColorBrush x:Key="MainDangerButtonBrush" Color="#B91C1C" />
        <SolidColorBrush x:Key="MainDangerButtonHoverBrush" Color="#5D0E0E" />
        <SolidColorBrush x:Key="MainDayToggleCheckedBrush" Color="#D8ECFF" />
        <SolidColorBrush x:Key="MainDayToggleCheckedBorderBrush" Color="#7AB8F5" />
        <SolidColorBrush x:Key="MainDayToggleCheckedForegroundBrush" Color="#003C6A" />
        <SolidColorBrush x:Key="MainDayTogglePressedBrush" Color="#003C6A" />
        <CornerRadius x:Key="MainCardCornerRadius">10</CornerRadius>
        <Thickness x:Key="MainCardExpanderPadding">14,16,14,16</Thickness>
        <Thickness x:Key="MainCardExpanderIconMargin">0,0,14,0</Thickness>
        <sys:Double x:Key="MainCardExpanderIconSize">24.0</sys:Double>
        <sys:Double x:Key="MainCardExpanderChevronSize">16.0</sys:Double>
        <views:AnimationFactorToValueConverter x:Key="MainAnimationFactorToValueConverter" />
        <Style x:Key="StatusIconButtonStyle" TargetType="{x:Type Button}">
            <Setter Property="Width" Value="16" />
            <Setter Property="Height" Value="16" />
            <Setter Property="MinWidth" Value="16" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Cursor" Value="Hand" />
        </Style>
        <Style x:Key="MainFlyoutBorderStyle" TargetType="{x:Type Border}">
            <Setter Property="Background" Value="{DynamicResource SolidBackgroundFillColorBaseBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource SurfaceStrokeColorFlyoutBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="10" />
            <Setter Property="SnapsToDevicePixels" Value="True" />
        </Style>
        <Style x:Key="MainFlyoutTitleStyle" TargetType="{x:Type TextBlock}">
            <Setter Property="FontSize" Value="16" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>
        <Style x:Key="MainFlyoutCaptionStyle" TargetType="{x:Type TextBlock}">
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Foreground" Value="{DynamicResource TextFillColorSecondaryBrush}" />
            <Setter Property="TextWrapping" Value="Wrap" />
        </Style>
        <Style x:Key="MainFlyoutCloseButtonStyle" TargetType="{x:Type Button}" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Width" Value="32" />
            <Setter Property="Height" Value="32" />
            <Setter Property="MinWidth" Value="32" />
            <Setter Property="Padding" Value="0" />
        </Style>
        <Style x:Key="MainFlyoutOptionButtonStyle" TargetType="{x:Type Button}" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Height" Value="34" />
            <Setter Property="HorizontalContentAlignment" Value="Left" />
            <Setter Property="Padding" Value="12,0" />
        </Style>
        <Style x:Key="MainFlyoutTextButtonStyle" TargetType="{x:Type Button}" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Padding" Value="4,0" />
            <Setter Property="MinWidth" Value="0" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="Cursor" Value="Hand" />
        </Style>
        <Style x:Key="MainIconOnlyButtonStyle" TargetType="{x:Type Button}" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Width" Value="32" />
            <Setter Property="Height" Value="32" />
            <Setter Property="MinWidth" Value="32" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="Cursor" Value="Hand" />
        </Style>
        <Style x:Key="MainNameTokenButtonStyle" TargetType="{x:Type Button}" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Height" Value="36" />
            <Setter Property="MinWidth" Value="0" />
            <Setter Property="Margin" Value="0" />
            <Setter Property="Padding" Value="14,0" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
        </Style>
        <Style x:Key="MainDangerAccentButtonStyle" TargetType="{x:Type Button}" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Background" Value="{StaticResource MainDangerButtonBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource MainDangerButtonBrush}" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Button}">
                        <Border x:Name="RootBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8">
                            <ContentPresenter Margin="{TemplateBinding Padding}"
                                              HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                              RecognizesAccessKey="True"
                                              TextElement.Foreground="{TemplateBinding Foreground}" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="RootBorder" Property="Background" Value="{StaticResource MainDangerButtonHoverBrush}" />
                                <Setter TargetName="RootBorder" Property="BorderBrush" Value="{StaticResource MainDangerButtonHoverBrush}" />
                                <Setter Property="Foreground" Value="White" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="RootBorder" Property="Background" Value="{StaticResource MainDangerButtonHoverBrush}" />
                                <Setter TargetName="RootBorder" Property="BorderBrush" Value="{StaticResource MainDangerButtonHoverBrush}" />
                                <Setter Property="Foreground" Value="White" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="RootBorder" Property="Opacity" Value="0.45" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="MainDayToggleButtonStyle" TargetType="{x:Type ToggleButton}">
            <Setter Property="Height" Value="36" />
            <Setter Property="MinWidth" Value="86" />
            <Setter Property="Margin" Value="6,4" />
            <Setter Property="Padding" Value="14,0" />
            <Setter Property="Background" Value="{DynamicResource ControlFillColorDefaultBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource ControlStrokeColorDefaultBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource TextFillColorPrimaryBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type ToggleButton}">
                        <Border x:Name="RootBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8">
                            <ContentPresenter Margin="{TemplateBinding Padding}"
                                              HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              RecognizesAccessKey="True"
                                              TextElement.Foreground="{TemplateBinding Foreground}" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="RootBorder" Property="Background" Value="{DynamicResource ControlFillColorSecondaryBrush}" />
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="RootBorder" Property="Background" Value="{StaticResource MainDayToggleCheckedBrush}" />
                                <Setter TargetName="RootBorder" Property="BorderBrush" Value="{StaticResource MainDayToggleCheckedBorderBrush}" />
                                <Setter Property="Foreground" Value="{StaticResource MainDayToggleCheckedForegroundBrush}" />
                            </Trigger>
                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="IsChecked" Value="True" />
                                    <Condition Property="IsMouseOver" Value="True" />
                                </MultiTrigger.Conditions>
                                <Setter TargetName="RootBorder" Property="Background" Value="{StaticResource MainDayTogglePressedBrush}" />
                                <Setter TargetName="RootBorder" Property="BorderBrush" Value="{StaticResource MainDayTogglePressedBrush}" />
                                <Setter Property="Foreground" Value="White" />
                            </MultiTrigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="RootBorder" Property="Background" Value="{StaticResource MainDayTogglePressedBrush}" />
                                <Setter TargetName="RootBorder" Property="BorderBrush" Value="{StaticResource MainDayTogglePressedBrush}" />
                                <Setter Property="Foreground" Value="White" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="RootBorder" Property="Opacity" Value="0.45" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="LocalSettingsToggleButtonStyle" TargetType="{x:Type ToggleButton}">
            <Setter Property="Height" Value="48" />
            <Setter Property="MinWidth" Value="150" />
            <Setter Property="Padding" Value="16,0" />
            <Setter Property="Background" Value="{DynamicResource ControlFillColorDefaultBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource ControlStrokeColorDefaultBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource TextFillColorPrimaryBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type ToggleButton}">
                        <Border x:Name="RootBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8">
                            <ContentPresenter Margin="{TemplateBinding Padding}"
                                              HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              RecognizesAccessKey="True"
                                              TextElement.Foreground="{TemplateBinding Foreground}" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="RootBorder" Property="Background" Value="{DynamicResource ControlFillColorSecondaryBrush}" />
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="RootBorder" Property="Background" Value="#EAF7EF" />
                                <Setter TargetName="RootBorder" Property="BorderBrush" Value="#65B984" />
                                <Setter Property="Foreground" Value="#14532D" />
                            </Trigger>
                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="IsChecked" Value="True" />
                                    <Condition Property="IsMouseOver" Value="True" />
                                </MultiTrigger.Conditions>
                                <Setter TargetName="RootBorder" Property="Background" Value="#D8EEE1" />
                                <Setter TargetName="RootBorder" Property="BorderBrush" Value="#3F9B65" />
                            </MultiTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <ControlTemplate x:Key="MainCardExpanderToggleButtonTemplate" TargetType="{x:Type ToggleButton}">
            <Border Padding="{TemplateBinding Padding}" Background="Transparent">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <ContentPresenter x:Name="ContentPresenter"
                                      Grid.Column="0"
                                      HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                      VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                      Content="{TemplateBinding Content}" />
                    <Grid x:Name="ChevronGrid"
                          Grid.Column="1"
                          VerticalAlignment="Center"
                          Background="Transparent"
                          RenderTransformOrigin="0.5,0.5">
                        <Grid.RenderTransform>
                            <RotateTransform Angle="0" />
                        </Grid.RenderTransform>
                        <ui:SymbolIcon x:Name="ControlChevronIcon"
                                       FontSize="{StaticResource MainCardExpanderChevronSize}"
                                       Foreground="{TemplateBinding Foreground}"
                                       Symbol="ChevronDown24" />
                    </Grid>
                </Grid>
            </Border>
            <ControlTemplate.Triggers>
                <Trigger Property="IsChecked" Value="True">
                    <Trigger.EnterActions>
                        <BeginStoryboard>
                            <Storyboard>
                                <DoubleAnimation Storyboard.TargetName="ChevronGrid"
                                                 Storyboard.TargetProperty="(Grid.RenderTransform).(RotateTransform.Angle)"
                                                 To="180"
                                                 Duration="00:00:00.167" />
                            </Storyboard>
                        </BeginStoryboard>
                    </Trigger.EnterActions>
                    <Trigger.ExitActions>
                        <BeginStoryboard>
                            <Storyboard>
                                <DoubleAnimation Storyboard.TargetName="ChevronGrid"
                                                 Storyboard.TargetProperty="(Grid.RenderTransform).(RotateTransform.Angle)"
                                                 To="0"
                                                 Duration="00:00:00.167" />
                            </Storyboard>
                        </BeginStoryboard>
                    </Trigger.ExitActions>
                </Trigger>
            </ControlTemplate.Triggers>
        </ControlTemplate>
        <Style TargetType="{x:Type ui:CardExpander}">
            <Setter Property="FocusVisualStyle" Value="{DynamicResource DefaultControlFocusVisualStyle}" />
            <Setter Property="Background" Value="{DynamicResource CardBackground}" />
            <Setter Property="Foreground" Value="{DynamicResource CardForeground}" />
            <Setter Property="BorderBrush" Value="{DynamicResource CardBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="{StaticResource MainCardExpanderPadding}" />
            <Setter Property="ContentPadding" Value="{StaticResource MainCardExpanderPadding}" />
            <Setter Property="HorizontalAlignment" Value="Stretch" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="FontSize" Value="{DynamicResource ControlContentThemeFontSize}" />
            <Setter Property="FontWeight" Value="Normal" />
            <Setter Property="CornerRadius" Value="{StaticResource MainCardCornerRadius}" />
            <Setter Property="IsExpanded" Value="False" />
            <Setter Property="SnapsToDevicePixels" Value="True" />
            <Setter Property="OverridesDefaultStyle" Value="True" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type ui:CardExpander}">
                        <Border x:Name="RootBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="{TemplateBinding CornerRadius}"
                                SnapsToDevicePixels="True">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <ToggleButton x:Name="ExpanderToggleButton"
                                              Grid.Row="0"
                                              Padding="{TemplateBinding Padding}"
                                              HorizontalAlignment="Stretch"
                                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                              HorizontalContentAlignment="Stretch"
                                              VerticalContentAlignment="Center"
                                              FontSize="{TemplateBinding FontSize}"
                                              Foreground="{TemplateBinding Foreground}"
                                              IsChecked="{Binding IsExpanded, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                                              IsEnabled="{TemplateBinding IsEnabled}"
                                              OverridesDefaultStyle="True"
                                              Template="{StaticResource MainCardExpanderToggleButtonTemplate}">
                                    <ToggleButton.Content>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <ContentControl x:Name="ControlIcon"
                                                            Grid.Column="0"
                                                            Margin="{StaticResource MainCardExpanderIconMargin}"
                                                            VerticalAlignment="Center"
                                                            Content="{TemplateBinding Icon}"
                                                            Focusable="False"
                                                            FontSize="{StaticResource MainCardExpanderIconSize}"
                                                            Foreground="{TemplateBinding Foreground}"
                                                            KeyboardNavigation.IsTabStop="False" />
                                            <ContentPresenter x:Name="HeaderContentPresenter"
                                                              Grid.Column="1"
                                                              Content="{TemplateBinding Header}"
                                                              TextElement.Foreground="{TemplateBinding Foreground}" />
                                        </Grid>
                                    </ToggleButton.Content>
                                </ToggleButton>
                                <Grid Grid.Row="1" ClipToBounds="True">
                                    <Border x:Name="ContentPresenterBorder"
                                            BorderBrush="{TemplateBinding BorderBrush}"
                                            BorderThickness="0,1,0,0"
                                            Visibility="Collapsed">
                                        <ContentPresenter x:Name="ContentPresenter"
                                                          Margin="{TemplateBinding ContentPadding}"
                                                          HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                                          VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                                          Content="{TemplateBinding Content}" />
                                        <Border.RenderTransform>
                                            <TranslateTransform>
                                                <TranslateTransform.Y>
                                                    <MultiBinding Converter="{StaticResource MainAnimationFactorToValueConverter}" ConverterParameter="negative">
                                                        <Binding ElementName="ContentPresenterBorder" Path="ActualHeight" />
                                                        <Binding ElementName="ContentPresenterBorder" Path="(animations:AnimationProperties.AnimationTagValue)" />
                                                    </MultiBinding>
                                                </TranslateTransform.Y>
                                            </TranslateTransform>
                                        </Border.RenderTransform>
                                    </Border>
                                </Grid>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsExpanded" Value="True">
                                <Trigger.EnterActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <ObjectAnimationUsingKeyFrames Storyboard.TargetName="ContentPresenterBorder" Storyboard.TargetProperty="(Border.Visibility)">
                                                <DiscreteObjectKeyFrame KeyTime="0" Value="{x:Static Visibility.Visible}" />
                                            </ObjectAnimationUsingKeyFrames>
                                            <DoubleAnimationUsingKeyFrames Storyboard.TargetName="ContentPresenterBorder" Storyboard.TargetProperty="(animations:AnimationProperties.AnimationTagValue)">
                                                <DiscreteDoubleKeyFrame KeyTime="0" Value="1.0" />
                                                <SplineDoubleKeyFrame KeySpline="0.0,0.0,0.0,1.0"
                                                                      KeyTime="0:0:0.333"
                                                                      Value="0.0" />
                                            </DoubleAnimationUsingKeyFrames>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.EnterActions>
                                <Trigger.ExitActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <ObjectAnimationUsingKeyFrames Storyboard.TargetName="ContentPresenterBorder" Storyboard.TargetProperty="(Border.Visibility)">
                                                <DiscreteObjectKeyFrame KeyTime="0" Value="{x:Static Visibility.Visible}" />
                                                <DiscreteObjectKeyFrame KeyTime="0:0:0.2" Value="{x:Static Visibility.Collapsed}" />
                                            </ObjectAnimationUsingKeyFrames>
                                            <DoubleAnimationUsingKeyFrames Storyboard.TargetName="ContentPresenterBorder" Storyboard.TargetProperty="(animations:AnimationProperties.AnimationTagValue)">
                                                <DiscreteDoubleKeyFrame KeyTime="0" Value="0.0" />
                                                <SplineDoubleKeyFrame KeySpline="1.0,1.0,0.0,1.0"
                                                                      KeyTime="0:0:0.167"
                                                                      Value="1.0" />
                                            </DoubleAnimationUsingKeyFrames>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.ExitActions>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="RootBorder" Property="Background" Value="{DynamicResource CardBackgroundDisabled}" />
                                <Setter TargetName="RootBorder" Property="BorderBrush" Value="{DynamicResource CardBorderBrushDisabled}" />
                                <Setter TargetName="ContentPresenter" Property="TextElement.Foreground" Value="{DynamicResource CardForegroundDisabled}" />
                                <Setter TargetName="ExpanderToggleButton" Property="Foreground" Value="{DynamicResource CardForegroundDisabled}" />
                            </Trigger>
                            <Trigger Property="Icon" Value="{x:Null}">
                                <Setter TargetName="ControlIcon" Property="Margin" Value="0" />
                                <Setter TargetName="ControlIcon" Property="Visibility" Value="Collapsed" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="ToolbarActiveButtonStyle" TargetType="{x:Type Button}" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Background" Value="#DDF6E6" />
            <Setter Property="BorderBrush" Value="#65B984" />
            <Setter Property="Foreground" Value="#14532D" />
        </Style>
        <Style x:Key="ToolbarStateButtonStyle" TargetType="{x:Type Button}" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Background" Value="{DynamicResource ControlFillColorDefaultBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource ControlStrokeColorDefaultBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource TextFillColorPrimaryBrush}" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Button}">
                        <Border x:Name="RootBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8">
                            <ContentPresenter Margin="{TemplateBinding Padding}"
                                              HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                              RecognizesAccessKey="True"
                                              TextElement.Foreground="{TemplateBinding Foreground}" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="RootBorder" Property="Background" Value="{DynamicResource ControlFillColorSecondaryBrush}" />
                            </Trigger>
                            <DataTrigger Binding="{Binding Tag, RelativeSource={RelativeSource TemplatedParent}}" Value="True">
                                <Setter TargetName="RootBorder" Property="Background" Value="#DDF6E6" />
                                <Setter TargetName="RootBorder" Property="BorderBrush" Value="#65B984" />
                                <Setter Property="Foreground" Value="#14532D" />
                            </DataTrigger>
                            <MultiDataTrigger>
                                <MultiDataTrigger.Conditions>
                                    <Condition Binding="{Binding Tag, RelativeSource={RelativeSource TemplatedParent}}" Value="True" />
                                    <Condition Binding="{Binding IsMouseOver, RelativeSource={RelativeSource TemplatedParent}}" Value="True" />
                                </MultiDataTrigger.Conditions>
                                <Setter TargetName="RootBorder" Property="Background" Value="#6F7B73" />
                                <Setter TargetName="RootBorder" Property="BorderBrush" Value="#65B984" />
                                <Setter Property="Foreground" Value="White" />
                            </MultiDataTrigger>
                            <MultiDataTrigger>
                                <MultiDataTrigger.Conditions>
                                    <Condition Binding="{Binding Tag, RelativeSource={RelativeSource TemplatedParent}}" Value="True" />
                                    <Condition Binding="{Binding IsPressed, RelativeSource={RelativeSource TemplatedParent}}" Value="True" />
                                </MultiDataTrigger.Conditions>
                                <Setter TargetName="RootBorder" Property="Background" Value="#6F7B73" />
                                <Setter TargetName="RootBorder" Property="BorderBrush" Value="#65B984" />
                                <Setter Property="Foreground" Value="White" />
                            </MultiDataTrigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="RootBorder" Property="Opacity" Value="0.45" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <DataTrigger Binding="{Binding Tag, RelativeSource={RelativeSource Self}}" Value="True">
                    <Setter Property="Background" Value="#DDF6E6" />
                    <Setter Property="BorderBrush" Value="#65B984" />
                    <Setter Property="Foreground" Value="#14532D" />
                </DataTrigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="MainNumberInputTextBoxStyle" TargetType="{x:Type ui:TextBox}" BasedOn="{StaticResource {x:Type ui:TextBox}}">
            <Setter Property="Height" Value="36" />
            <Setter Property="MinHeight" Value="36" />
            <Setter Property="Padding" Value="12,0" />
            <Setter Property="ClearButtonEnabled" Value="False" />
            <Setter Property="TextAlignment" Value="Center" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <EventSetter Event="PreviewTextInput" Handler="NumberInputPreviewTextInput" />
            <EventSetter Event="PreviewKeyDown" Handler="NumberInputPreviewKeyDown" />
            <EventSetter Event="DataObject.Pasting" Handler="NumberInputPasting" />
        </Style>
        <Style x:Key="MainAccentButtonStyle" TargetType="{x:Type Button}" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Background" Value="{DynamicResource SystemAccentColorPrimaryBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource SystemAccentColorPrimaryBrush}" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Button}">
                        <Border x:Name="RootBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                              Margin="{TemplateBinding Padding}"
                                              RecognizesAccessKey="True"
                                              TextElement.Foreground="{TemplateBinding Foreground}" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="RootBorder" Property="Background" Value="{StaticResource MainAccentHoverBrush}" />
                                <Setter TargetName="RootBorder" Property="BorderBrush" Value="{StaticResource MainAccentHoverBrush}" />
                                <Setter Property="Foreground" Value="White" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="RootBorder" Property="Background" Value="{StaticResource MainAccentPressedBrush}" />
                                <Setter TargetName="RootBorder" Property="BorderBrush" Value="{StaticResource MainAccentPressedBrush}" />
                                <Setter Property="Foreground" Value="White" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="RootBorder" Property="Opacity" Value="0.45" />
                                <Setter Property="Foreground" Value="White" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </ui:FluentWindow.Resources>
    <Grid>
        <ui:Grid x:Name="MainContentRoot" Margin="8,42,8,8" RowDefinitions="Auto,*,Auto">
            <ui:Grid Grid.Row="0" ColumnDefinitions="Auto,*,Auto">
                <ui:StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="8">
                    <Button MinWidth="72"
                            Style="{StaticResource MainAccentButtonStyle}"
                            Click="OpenAddRoomFlyoutClick">
                        <Button.Content>
                            <ui:StackPanel Orientation="Horizontal" Spacing="8">
                                <ui:FontIcon FontFamily="{DynamicResource SymbolThemeFontFamily}" Glyph="{x:Static ui:FontSymbols.Add}" />
                                <TextBlock Text="{I18N ToolbarNew}" />
                            </ui:StackPanel>
                        </Button.Content>
                    </Button>
                    <Button MinWidth="72"
                            Command="{Binding ToggleMonitorCommand}"
                            Style="{StaticResource ToolbarStateButtonStyle}"
                            Tag="{Binding StatusOfIsMonitorRunning}">
                        <Button.Content>
                            <ui:StackPanel Orientation="Horizontal" Spacing="8">
                                <ui:FontIcon FontFamily="{DynamicResource SymbolThemeFontFamily}" Glyph="{x:Static ui:FontSymbols.Radar}" />
                                <TextBlock Text="{I18N ToolbarMonitor}" />
                            </ui:StackPanel>
                        </Button.Content>
                    </Button>
                    <Button MinWidth="72"
                            Command="{Binding ToggleRecordCommand}"
                            Style="{StaticResource ToolbarStateButtonStyle}"
                            Tag="{Binding StatusOfIsToRecord}">
                        <Button.Content>
                            <ui:StackPanel Orientation="Horizontal" Spacing="8">
                                <ui:FontIcon FontFamily="{DynamicResource SymbolThemeFontFamily}" Glyph="{x:Static ui:FontSymbols.Record}" />
                                <TextBlock Text="{I18N ToolbarRecord}" />
                            </ui:StackPanel>
                        </Button.Content>
                    </Button>
                    <Button MinWidth="72" Click="OpenScreenRecordListClick">
                        <Button.Content>
                            <ui:StackPanel Orientation="Horizontal" Spacing="8">
                                <ui:FontIcon FontFamily="{DynamicResource SymbolThemeFontFamily}" Glyph="{x:Static ui:FontSymbols.Video}" />
                                <TextBlock Text="{I18N ToolbarScreenRecordList}" />
                            </ui:StackPanel>
                        </Button.Content>
                    </Button>
                    <Button MinWidth="72" Command="{Binding OpenSettingsDialogCommand}">
                        <Button.Content>
                            <ui:StackPanel Orientation="Horizontal" Spacing="8">
                                <ui:FontIcon FontFamily="{DynamicResource SymbolThemeFontFamily}" Glyph="{x:Static ui:FontSymbols.Settings}" />
                                <TextBlock Text="{I18N ButtonOfSettings}" />
                            </ui:StackPanel>
                        </Button.Content>
                    </Button>
                    <Button MinWidth="72" Click="OpenDeveloperToolsClick">
                        <Button.Content>
                            <ui:StackPanel VerticalAlignment="Center" Orientation="Horizontal" Spacing="8">
                                <ui:FontIcon Margin="0,2,0,0" VerticalAlignment="Center" FontFamily="{DynamicResource SymbolThemeFontFamily}" Glyph="{x:Static ui:FontSymbols.DeviceMonitorRightPic}" />
                                <TextBlock VerticalAlignment="Center" Text="开发" />
                            </ui:StackPanel>
                        </Button.Content>
                    </Button>
                    <Button MinWidth="72" Click="OpenAboutFlyoutClick">
                        <Button.Content>
                            <ui:StackPanel Orientation="Horizontal" Spacing="8">
                                <ui:FontIcon FontFamily="{DynamicResource SymbolThemeFontFamily}" Glyph="{x:Static ui:FontSymbols.Info}" />
                                <TextBlock Text="{I18N About}" />
                            </ui:StackPanel>
                        </Button.Content>
                    </Button>
                    <Button MinWidth="72" Command="{Binding ExitApplicationCommand}">
                        <Button.Content>
                            <ui:StackPanel Orientation="Horizontal" Spacing="8">
                                <ui:FontIcon FontFamily="{DynamicResource SymbolThemeFontFamily}" Glyph="{x:Static ui:FontSymbols.PowerButton}" />
                                <TextBlock Text="{I18N ToolbarExit}" />
                            </ui:StackPanel>
                        </Button.Content>
                    </Button>
                </ui:StackPanel>
                <ui:StackPanel Grid.Column="2"
                               HorizontalAlignment="Right"
                               Orientation="Horizontal"
                               Spacing="8">
                    <Button MinWidth="80" Command="{Binding OpenSaveFolderCommand}">
                        <Button.Content>
                            <ui:StackPanel Orientation="Horizontal" Spacing="8">
                                <ui:FontIcon FontFamily="{DynamicResource SymbolThemeFontFamily}" Glyph="{x:Static ui:FontSymbols.FolderOpen}" />
                                <TextBlock Text="{I18N SaveFolder}" />
                            </ui:StackPanel>
                        </Button.Content>
                    </Button>
                </ui:StackPanel>
            </ui:Grid>
            <ui:Grid Grid.Row="1"
                     Margin="0,8,0,0"
                     ColumnDefinitions="13*,7*">
                <ui:Grid.Resources>
                    <c:ValueConverterGroup x:Key="NotZeroIntToToVisibilityConverter">
                        <c:IntToBoolConverter TrueValue="0" />
                        <c:BoolToVisibilityConverter />
                    </c:ValueConverterGroup>
                    <Style x:Key="OperationButtonStyle" TargetType="{x:Type Button}" BasedOn="{StaticResource {x:Type Button}}">
                        <Setter Property="Height" Value="34" />
                        <Setter Property="MinWidth" Value="78" />
                        <Setter Property="Padding" Value="10,0" />
                        <Setter Property="Margin" Value="0,0,8,8" />
                    </Style>
                    <Style x:Key="InfoIconButtonStyle" TargetType="{x:Type Button}" BasedOn="{StaticResource {x:Type Button}}">
                        <Setter Property="Width" Value="20" />
                        <Setter Property="Height" Value="26" />
                        <Setter Property="MinWidth" Value="20" />
                        <Setter Property="MaxWidth" Value="20" />
                        <Setter Property="MinHeight" Value="24" />
                        <Setter Property="MaxHeight" Value="26" />
                        <Setter Property="Padding" Value="0" />
                        <Setter Property="BorderBrush" Value="{DynamicResource ControlStrokeColorDefaultBrush}" />
                        <Setter Property="BorderThickness" Value="1" />
                        <Setter Property="Background" Value="{DynamicResource ControlFillColorDefaultBrush}" />
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="{x:Type Button}">
                                    <Border x:Name="RootBorder"
                                            Background="{TemplateBinding Background}"
                                            BorderBrush="{TemplateBinding BorderBrush}"
                                            BorderThickness="{TemplateBinding BorderThickness}"
                                            CornerRadius="5">
                                        <ContentPresenter HorizontalAlignment="Center"
                                                          VerticalAlignment="Center"
                                                          RecognizesAccessKey="True" />
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="RootBorder" Property="Background" Value="{DynamicResource ControlFillColorSecondaryBrush}" />
                                        </Trigger>
                                        <Trigger Property="IsPressed" Value="True">
                                            <Setter TargetName="RootBorder" Property="Background" Value="{DynamicResource ControlFillColorTertiaryBrush}" />
                                        </Trigger>
                                        <Trigger Property="IsEnabled" Value="False">
                                            <Setter TargetName="RootBorder" Property="Opacity" Value="0.5" />
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                    <Style x:Key="RoomCardListBoxStyle" TargetType="{x:Type ListBox}">
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="{x:Type ListBox}">
                                    <ScrollViewer x:Name="RoomCardScrollViewer"
                                                  Padding="{TemplateBinding Padding}"
                                                  Focusable="False"
                                                  HorizontalScrollBarVisibility="{TemplateBinding ScrollViewer.HorizontalScrollBarVisibility}"
                                                  VerticalScrollBarVisibility="{TemplateBinding ScrollViewer.VerticalScrollBarVisibility}">
                                        <ScrollViewer.Template>
                                            <ControlTemplate TargetType="{x:Type ScrollViewer}">
                                                <Grid>
                                                    <ScrollContentPresenter CanContentScroll="{TemplateBinding CanContentScroll}"
                                                                            Content="{TemplateBinding Content}"
                                                                            ContentTemplate="{TemplateBinding ContentTemplate}" />
                                                    <ScrollBar x:Name="PART_VerticalScrollBar"
                                                               Width="8"
                                                               Margin="0,0,-2,0"
                                                               HorizontalAlignment="Right"
                                                               Maximum="{TemplateBinding ScrollableHeight}"
                                                               Orientation="Vertical"
                                                               ViewportSize="{TemplateBinding ViewportHeight}"
                                                               Value="{TemplateBinding VerticalOffset}"
                                                               Visibility="{TemplateBinding ComputedVerticalScrollBarVisibility}" />
                                                </Grid>
                                            </ControlTemplate>
                                        </ScrollViewer.Template>
                                        <ItemsPresenter />
                                    </ScrollViewer>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </ui:Grid.Resources>
                <Border Grid.Column="0"
                        x:Name="RoomCardPanel"
                        Padding="10"
                        Background="#0E000000"
                        BorderBrush="{DynamicResource SystemFillColorSolidNeutralBrush}"
                        BorderThickness="1"
                        CornerRadius="8"
                        ClipToBounds="False"
                        PreviewMouseLeftButtonDown="RoomCardListPreviewMouseLeftButtonDown"
                        PreviewMouseLeftButtonUp="RoomCardListPreviewMouseLeftButtonUp"
                        PreviewMouseMove="RoomCardListPreviewMouseMove"
                        PreviewMouseRightButtonDown="RoomCardListPreviewMouseRightButtonDown"
                        MouseLeftButtonDown="RoomCardPanelMouseLeftButtonDown">
                    <Border.ContextMenu>
                        <ContextMenu Placement="MousePoint" DataContext="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource Self}}">
                            <MenuItem Header="{I18N CardSize}">
                                <MenuItem Header="{I18N CardSizeLarge}" Click="SetRoomCardLargeClick" />
                                <MenuItem Header="{I18N CardSizeMedium}" Click="SetRoomCardMediumClick" />
                                <MenuItem Header="{I18N CardSizeSmall}" Click="SetRoomCardSmallClick" />
                            </MenuItem>
                            <MenuItem Header="{I18N CardSort}">
                                <MenuItem Header="{I18N CardSortByName}" Command="{Binding SortRoomsByNameCommand}" />
                                <MenuItem Header="{I18N CardSortByAddedAt}" Command="{Binding SortRoomsByAddedAtCommand}" />
                            </MenuItem>
                            <Separator />
                            <MenuItem Header="{I18N CardRefresh}" Command="{Binding RefreshRoomCardsCommand}" />
                            <MenuItem Header="{I18N CardEdit}" Command="{Binding ToggleCardEditModeCommand}" />
                        </ContextMenu>
                    </Border.ContextMenu>
                    <Grid ClipToBounds="False">
                        <ListBox x:Name="RoomCardList"
                                 Background="Transparent"
                                 BorderThickness="0"
                                 ClipToBounds="False"
                                 ItemsSource="{Binding RoomStatuses}"
                                 Padding="0"
                                 Style="{StaticResource RoomCardListBoxStyle}"
                                 Loaded="RoomCardListLoaded"
                                 SizeChanged="RoomCardListSizeChanged"
                                 LostMouseCapture="RoomCardListLostMouseCapture"
                                 ScrollViewer.CanContentScroll="True"
                                 ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                 ScrollViewer.VerticalScrollBarVisibility="Auto"
                                 SelectedItem="{Binding SelectedItem, Mode=TwoWay}">
                            <ListBox.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel IsItemsHost="True"
                                               Width="{Binding RoomCardPanelWidth, RelativeSource={RelativeSource AncestorType={x:Type views:MainWindow}}}"
                                               HorizontalAlignment="Center"
                                               ItemWidth="{Binding RoomCardItemWidth, RelativeSource={RelativeSource AncestorType={x:Type views:MainWindow}}}"
                                               ItemHeight="{Binding RoomCardItemHeight, RelativeSource={RelativeSource AncestorType={x:Type views:MainWindow}}}" />
                                </ItemsPanelTemplate>
                            </ListBox.ItemsPanel>
                            <ListBox.ItemContainerStyle>
                                <Style TargetType="{x:Type ListBoxItem}">
                                    <Setter Property="HorizontalContentAlignment" Value="Center" />
                                    <Setter Property="VerticalContentAlignment" Value="Center" />
                                    <Setter Property="Margin" Value="0" />
                                    <Setter Property="Padding" Value="0" />
                                    <Setter Property="Background" Value="Transparent" />
                                    <Setter Property="BorderBrush" Value="Transparent" />
                                    <Setter Property="BorderThickness" Value="0" />
                                    <Setter Property="ClipToBounds" Value="False" />
                                    <Setter Property="FocusVisualStyle" Value="{x:Null}" />
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="{x:Type ListBoxItem}">
                                                <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                                                  VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                                                  SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}" />
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </ListBox.ItemContainerStyle>
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Border x:Name="RoomCardShell"
                                            Width="{Binding RoomCardWidth, RelativeSource={RelativeSource AncestorType={x:Type views:MainWindow}}}"
                                            Height="{Binding RoomCardHeight, RelativeSource={RelativeSource AncestorType={x:Type views:MainWindow}}}"
                                            Margin="{Binding RoomCardMargin, RelativeSource={RelativeSource AncestorType={x:Type views:MainWindow}}}"
                                            Padding="{Binding RoomCardPadding, RelativeSource={RelativeSource AncestorType={x:Type views:MainWindow}}}"
                                            Background="#12000000"
                                            BorderBrush="{DynamicResource SystemFillColorSolidNeutralBrush}"
                                            BorderThickness="1"
                                            CornerRadius="8"
                                            TextElement.Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                                            RenderTransformOrigin="0.5,0.5"
                                            SnapsToDevicePixels="True"
                                            Tag="{Binding DataContext, RelativeSource={RelativeSource AncestorType={x:Type ListBox}}}">
                                        <Border.RenderTransform>
                                            <RotateTransform x:Name="RoomCardAngle" Angle="0" />
                                        </Border.RenderTransform>
                                        <Border.ContextMenu>
                                            <ContextMenu DataContext="{Binding PlacementTarget.Tag, RelativeSource={RelativeSource Self}}">
                                                <MenuItem Header="{I18N Preview}" Command="{Binding PreviewCommand}">
                                                    <MenuItem.Icon>
                                                        <ui:FontIcon FontFamily="{DynamicResource SymbolThemeFontFamily}" Glyph="{x:Static ui:FontSymbols.Play}" />
                                                    </MenuItem.Icon>
                                                </MenuItem>
                                                <MenuItem Header="{I18N GotoLiveRoom}" Command="{Binding GotoRoomUrlCommand}">
                                                    <MenuItem.Icon>
                                                        <ui:FontIcon FontFamily="{DynamicResource SymbolThemeFontFamily}" Glyph="{x:Static ui:FontSymbols.OpenInNewWindow}" />
                                                    </MenuItem.Icon>
                                                </MenuItem>
                                                <MenuItem Header="{I18N SaveFolder}" Command="{Binding OpenSaveFolderCommand}">
                                                    <MenuItem.Icon>
                                                        <ui:FontIcon FontFamily="{DynamicResource SymbolThemeFontFamily}" Glyph="{x:Static ui:FontSymbols.FolderOpen}" />
                                                    </MenuItem.Icon>
                                                </MenuItem>
                                                <Separator />
                                                <MenuItem Header="{I18N RowUpRoom}" Command="{Binding RowUpRoomUrlCommand}">
                                                    <MenuItem.Icon>
                                                        <ui:FontIcon FontFamily="{DynamicResource SymbolThemeFontFamily}" Glyph="{x:Static ui:FontSymbols.ChevronUp}" />
                                                    </MenuItem.Icon>
                                                </MenuItem>
                                                <MenuItem Header="{I18N RowDownRoom}" Command="{Binding RowDownRoomUrlCommand}">
                                                    <MenuItem.Icon>
                                                        <ui:FontIcon FontFamily="{DynamicResource SymbolThemeFontFamily}" Glyph="{x:Static ui:FontSymbols.ChevronDown}" />
                                                    </MenuItem.Icon>
                                                </MenuItem>
                                                <MenuItem Header="{I18N StopRecord}" Command="{Binding StopRecordCommand}">
                                                    <MenuItem.Icon>
                                                        <ui:FontIcon FontFamily="{DynamicResource SymbolThemeFontFamily}" Glyph="{x:Static ui:FontSymbols.Stop}" />
                                                    </MenuItem.Icon>
                                                </MenuItem>
                                                <Separator />
                                                <MenuItem Header="{I18N LiveNotification}"
                                                          Command="{Binding IsToNotifyCommand}"
                                                          IsCheckable="True"
                                                          IsChecked="{Binding SelectedItem.IsToNotify, Mode=TwoWay}" />
                                                <MenuItem Header="{I18N EnableRecord}"
                                                          Command="{Binding IsToRecordCommand}"
                                                          IsCheckable="True"
                                                          IsChecked="{Binding SelectedItem.IsToRecord, Mode=TwoWay}" />
                                                <Separator />
                                                <MenuItem Header="{I18N RemoveRoom}" Command="{Binding RemoveRoomUrlCommand}">
                                                    <MenuItem.Icon>
                                                        <ui:FontIcon FontFamily="{DynamicResource SymbolThemeFontFamily}" Glyph="{x:Static ui:FontSymbols.CalculatorMultiply}" />
                                                    </MenuItem.Icon>
                                                </MenuItem>
                                            </ContextMenu>
                                        </Border.ContextMenu>
                                        <Grid ClipToBounds="False">
                                            <Border x:Name="RoomCardFlashOverlay"
                                                    Background="White"
                                                    CornerRadius="8"
                                                    Panel.ZIndex="2"
                                                    IsHitTestVisible="False"
                                                    Opacity="0" />
                                            <ui:Grid RowDefinitions="Auto,*,Auto">
                                                <Grid Grid.Row="0" ClipToBounds="False">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="{Binding RoomCardHeaderColumnWidth, RelativeSource={RelativeSource AncestorType={x:Type views:MainWindow}}}" />
                                                    <ColumnDefinition Width="*" />
                                                </Grid.ColumnDefinitions>
                                                <Grid Width="{Binding RoomCardAvatarContainerSize, RelativeSource={RelativeSource AncestorType={x:Type views:MainWindow}}}"
                                                      Height="{Binding RoomCardAvatarContainerSize, RelativeSource={RelativeSource AncestorType={x:Type views:MainWindow}}}"
                                                      HorizontalAlignment="Left"
                                                      VerticalAlignment="Top"
                                                      Margin="{Binding RoomCardAvatarMargin, RelativeSource={RelativeSource AncestorType={x:Type views:MainWindow}}}"
                                                      ClipToBounds="False">
                                                    <Ellipse Width="{Binding RoomCardAvatarSize, RelativeSource={RelativeSource AncestorType={x:Type views:MainWindow}}}"
                                                             Height="{Binding RoomCardAvatarSize, RelativeSource={RelativeSource AncestorType={x:Type views:MainWindow}}}"
                                                             HorizontalAlignment="Center"
                                                             VerticalAlignment="Center"
                                                             Fill="#18000000" />
                                                    <Ellipse x:Name="RoomCardAvatarImage"
                                                             Width="{Binding RoomCardAvatarSize, RelativeSource={RelativeSource AncestorType={x:Type views:MainWindow}}}"
                                                             Height="{Binding RoomCardAvatarSize, RelativeSource={RelativeSource AncestorType={x:Type views:MainWindow}}}"
                                                             HorizontalAlignment="Center"
                                                             VerticalAlignment="Center"
                                                             RenderOptions.BitmapScalingMode="HighQuality"
                                                             SnapsToDevicePixels="True">
                                                        <Ellipse.Fill>
                                                            <ImageBrush ImageSource="{Binding AvatarDisplaySource}" Stretch="UniformToFill" />
                                                        </Ellipse.Fill>
                                                    </Ellipse>
                                                    <TextBlock x:Name="RoomCardAvatarPlaceholder"
                                                               FontFamily="Segoe MDL2 Assets"
                                                               FontSize="{Binding RoomCardAvatarIconSize, RelativeSource={RelativeSource AncestorType={x:Type views:MainWindow}}}"
                                                               Text="&#xE77B;"
                                                               HorizontalAlignment="Center"
                                                               VerticalAlignment="Center"
                                                               Visibility="Collapsed" />
                                                </Grid>
                                               <ui:StackPanel Grid.Column="1"
                                                               VerticalAlignment="Center"
                                                               Spacing="2">
                                                    <TextBlock FontSize="{Binding RoomCardNameFontSize, RelativeSource={RelativeSource AncestorType={x:Type views:MainWindow}}}"
                                                               FontWeight="SemiBold"
                                                               Text="{Binding NickName}"
                                                               TextTrimming="CharacterEllipsis" />
                                                    <ui:StackPanel Orientation="Horizontal" Spacing="4">
                                                        <Border Width="{Binding RoomCardPlatformFontSize, RelativeSource={RelativeSource AncestorType={x:Type views:MainWindow}}}"
                                                                Height="{Binding RoomCardPlatformFontSize, RelativeSource={RelativeSource AncestorType={x:Type views:MainWindow}}}"
                                                                CornerRadius="99"
                                                                RenderOptions.BitmapScalingMode="HighQuality">
                                                            <Border.Background>
                                                                <ImageBrush ImageSource="{Binding PlatformIconSource}" Stretch="UniformToFill" />
                                                            </Border.Background>
                                                        </Border>
                                                        <TextBlock FontSize="{Binding RoomCardPlatformFontSize, RelativeSource={RelativeSource AncestorType={x:Type views:MainWindow}}}"
                                                                   Opacity="0.62"
                                                                   Text="{Binding PlatformDisplayName}"
                                                                   TextTrimming="CharacterEllipsis" />
                                                    </ui:StackPanel>
                                                </ui:StackPanel>
                                                </Grid>
                                                <TextBlock Grid.Row="1"
                                                       Margin="0,5,0,0"
                                                       FontSize="{Binding RoomCardTitleFontSize, RelativeSource={RelativeSource AncestorType={x:Type views:MainWindow}}}"
                                                       LineHeight="{Binding RoomCardTitleLineHeight, RelativeSource={RelativeSource AncestorType={x:Type views:MainWindow}}}"
                                                       MaxHeight="{Binding RoomCardTitleMaxHeight, RelativeSource={RelativeSource AncestorType={x:Type views:MainWindow}}}"
                                                       Opacity="0.72"
                                                       Text="{Binding Title}"
                                                       TextTrimming="CharacterEllipsis"
                                                       TextWrapping="Wrap"
                                                       Visibility="{Binding RoomCardTitleVisibility, RelativeSource={RelativeSource AncestorType={x:Type views:MainWindow}}}" />
                                                <ui:Grid Grid.Row="2"
                                                     Margin="0,6,0,0"
                                                     VerticalAlignment="Bottom"
                                                     ColumnDefinitions="*,*">
                                                <Border Grid.Column="0"
                                                        Margin="0,0,4,0"
                                                        Height="{Binding RoomCardChipMinHeight, RelativeSource={RelativeSource AncestorType={x:Type views:MainWindow}}}"
                                                        Padding="{Binding RoomCardChipPadding, RelativeSource={RelativeSource AncestorType={x:Type views:MainWindow}}}"
                                                        Background="#20337DFF"
                                                        CornerRadius="10">
                                                    <TextBlock FontSize="{Binding RoomCardChipFontSize, RelativeSource={RelativeSource AncestorType={x:Type views:MainWindow}}}"
                                                               HorizontalAlignment="Center"
                                                               VerticalAlignment="Center"
                                                               Text="{Binding StreamStatusText}"
                                                               TextAlignment="Center"
                                                               TextTrimming="CharacterEllipsis" />
                                                </Border>
                                                <Border Grid.Column="1"
                                                        Margin="4,0,0,0"
                                                        Height="{Binding RoomCardChipMinHeight, RelativeSource={RelativeSource AncestorType={x:Type views:MainWindow}}}"
                                                        Padding="{Binding RoomCardChipPadding, RelativeSource={RelativeSource AncestorType={x:Type views:MainWindow}}}"
                                                        Background="#2026A269"
                                                        CornerRadius="10">
                                                    <TextBlock FontSize="{Binding RoomCardChipFontSize, RelativeSource={RelativeSource AncestorType={x:Type views:MainWindow}}}"
                                                               HorizontalAlignment="Center"
                                                               VerticalAlignment="Center"
                                                               Text="{Binding RecordStatusText}"
                                                               TextAlignment="Center"
                                                               TextTrimming="CharacterEllipsis" />
                                                </Border>
                                                </ui:Grid>
                                            </ui:Grid>
                                        </Grid>
                                    </Border>
                                    <DataTemplate.Triggers>
                                        <DataTrigger Binding="{Binding IsSelected, RelativeSource={RelativeSource AncestorType={x:Type ListBoxItem}}}" Value="True">
                                            <Setter TargetName="RoomCardShell" Property="Background" Value="#2A4DA7B0" />
                                            <Setter TargetName="RoomCardShell" Property="BorderBrush" Value="#884DA7B0" />
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding AvatarDisplaySource}" Value="">
                                            <Setter TargetName="RoomCardAvatarImage" Property="Visibility" Value="Collapsed" />
                                            <Setter TargetName="RoomCardAvatarPlaceholder" Property="Visibility" Value="Visible" />
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding DataContext.IsCardEditMode, RelativeSource={RelativeSource AncestorType={x:Type ListBox}}}" Value="True">
                                            <DataTrigger.EnterActions>
                                                <BeginStoryboard x:Name="RoomCardWiggleStoryboard">
                                                    <Storyboard AutoReverse="True" RepeatBehavior="Forever">
                                                        <DoubleAnimation Storyboard.TargetName="RoomCardAngle"
                                                                         Storyboard.TargetProperty="Angle"
                                                                         From="-0.45"
                                                                         To="0.45"
                                                                         Duration="0:0:0.12"
                                                                         FillBehavior="Stop" />
                                                    </Storyboard>
                                                </BeginStoryboard>
                                            </DataTrigger.EnterActions>
                                            <DataTrigger.ExitActions>
                                                <StopStoryboard BeginStoryboardName="RoomCardWiggleStoryboard" />
                                            </DataTrigger.ExitActions>
                                        </DataTrigger>
                                    </DataTemplate.Triggers>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                        <ui:StackPanel HorizontalAlignment="Center"
                                       VerticalAlignment="Center"
                                       Opacity="0.8"
                                       Spacing="8"
                                       Visibility="{Binding RoomStatuses.Count, Converter={StaticResource NotZeroIntToToVisibilityConverter}}">
                            <ui:FontIcon FontFamily="{DynamicResource CustomSymbolThemeFontFamily}"
                                         FontSize="40"
                                         Glyph="{x:Static ui:CustomFontSymbols.Empty}" />
                            <TextBlock Text="{I18N EmptyRoomHint}" />
                        </ui:StackPanel>
                    </Grid>
                </Border>
                <ScrollViewer Grid.Column="1"
                              Margin="8,0,0,0"
                              HorizontalScrollBarVisibility="Disabled"
                              VerticalScrollBarVisibility="Auto">
                    <Border MinHeight="520"
                            Padding="18"
                            Background="#0E000000"
                            BorderBrush="{DynamicResource SystemFillColorSolidNeutralBrush}"
                            BorderThickness="1"
                            CornerRadius="8">
                        <ui:StackPanel Spacing="16">
                            <ui:Grid ColumnDefinitions="52,*">
                                <vio:PersonPicture Width="44"
                                                   Height="44"
                                                   HorizontalAlignment="Left"
                                                   VerticalAlignment="Center"
                                                   ProfilePicture="{Binding SelectedItem.AvatarDisplaySource}"
                                                   RenderOptions.BitmapScalingMode="HighQuality"
                                                   SnapsToDevicePixels="True" />
                                <ui:StackPanel Grid.Column="1"
                                               VerticalAlignment="Center"
                                               Spacing="6">
                                    <TextBlock FontSize="20"
                                               FontWeight="SemiBold"
                                               Text="{Binding SelectedItem.NickName}"
                                               TextTrimming="CharacterEllipsis" />
                                    <TextBlock FontSize="12"
                                               Opacity="0.65"
                                               Text="{Binding SelectedItem.UidDisplayText}"
                                               TextTrimming="CharacterEllipsis" />
                                </ui:StackPanel>
                            </ui:Grid>
                            <Separator />
                            <ui:Grid ColumnDefinitions="*,Auto">
                                <TextBlock FontSize="14"
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource SystemAccentColorPrimaryBrush}"
                                           Text="{I18N RoomDetails}" />
                                    <Button Grid.Column="1"
                                        Style="{StaticResource InfoIconButtonStyle}"
                                        Command="{Binding RefreshSelectedRoomInfoCommand}"
                                        ToolTip="{I18N CardRefresh}">
                                    <ui:FontIcon FontFamily="{DynamicResource SymbolThemeFontFamily}"
                                                 FontSize="11"
                                                 Glyph="{x:Static ui:FontSymbols.Sync}"
                                                 RenderTransformOrigin="0.5,0.5">
                                        <ui:FontIcon.RenderTransform>
                                            <RotateTransform />
                                        </ui:FontIcon.RenderTransform>
                                        <ui:FontIcon.Style>
                                            <Style TargetType="{x:Type ui:FontIcon}">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsRefreshingSelectedRoomInfo}" Value="True">
                                                        <DataTrigger.EnterActions>
                                                            <BeginStoryboard x:Name="SelectedRoomInfoRefreshSpin">
                                                                <Storyboard RepeatBehavior="Forever">
