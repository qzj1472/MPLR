                                                    Style="{StaticResource MainNumberInputTextBoxStyle}"
                                                    Text="{Binding LocalRoutineScheduleEndHour, ElementName=Root, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                        <TextBlock Grid.Column="5"
                                                   Margin="6,0"
                                                   VerticalAlignment="Center"
                                                   FontSize="18"
                                                   Text=":" />
                                        <ui:TextBox Grid.Column="6"
                                                    FontSize="16"
                                                    Style="{StaticResource MainNumberInputTextBoxStyle}"
                                                    Text="{Binding LocalRoutineScheduleEndMinute, ElementName=Root, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                    </ui:Grid>
                                </ui:StackPanel>
                            </ui:CardExpander>
                            <ui:Card Padding="14">
                                <ui:Grid MinHeight="54" ColumnDefinitions="Auto,*,112,12,92">
                                    <ui:FontIcon Grid.Column="0"
                                                 Margin="4,0,18,0"
                                                 VerticalAlignment="Center"
                                                 FontFamily="{DynamicResource SymbolThemeFontFamily}"
                                                 FontSize="22"
                                                 Glyph="{x:Static ui:FontSymbols.DeviceMonitorRightPic}" />
                                    <ui:Grid Grid.Column="1" RowDefinitions="Auto,Auto">
                                        <TextBlock Grid.Row="0" Text="{I18N RoutineInterval}" />
                                        <TextBlock Grid.Row="1"
                                                   FontSize="11"
                                                   Foreground="{DynamicResource SystemFillColorSolidNeutralBrush}"
                                                   Text="{I18N RoutineIntervalHint}" />
                                    </ui:Grid>
                                    <ui:TextBox Grid.Column="2"
                                                Width="112"
                                                Style="{StaticResource MainNumberInputTextBoxStyle}"
                                                Tag="Decimal"
                                                Text="{Binding LocalRoutineIntervalValue, ElementName=Root, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                    <ComboBox Grid.Column="4"
                                              MinWidth="92"
                                              SelectedIndex="{Binding LocalRoutineIntervalUnitIndex, ElementName=Root, Mode=TwoWay}">
                                        <ComboBoxItem Content="{Binding RoutineIntervalSecondsText, ElementName=Root}" />
                                        <ComboBoxItem Content="{Binding RoutineIntervalMinutesText, ElementName=Root}" />
                                    </ComboBox>
                                </ui:Grid>
                            </ui:Card>
                            <ui:CardExpander>
                                <ui:CardExpander.Header>
                                    <ui:Grid ColumnDefinitions="Auto,*,Auto">
                                        <Grid Grid.Column="0" Margin="0,0,12,0">
                                            <TextBlock MinWidth="26"
                                                       Margin="4,0,0,0"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center"
                                                       FontFamily="{DynamicResource SymbolThemeFontFamily}"
                                                       FontSize="18"
                                                       Text="{x:Static ui:FontSymbols.Filter}" />
                                        </Grid>
                                        <ui:Grid Grid.Column="1" RowDefinitions="Auto,Auto">
                                            <TextBlock Grid.Row="0" Text="{I18N RecordFormat}" />
                                            <TextBlock Grid.Row="1"
                                                       FontSize="11"
                                                       Foreground="{DynamicResource SystemFillColorSolidNeutralBrush}"
                                                       Text="{I18N RecordFormatHint}" />
                                        </ui:Grid>
                                        <Grid Grid.Column="2" Margin="0,0,12,0">
                                            <ComboBox MinWidth="150" SelectedIndex="{Binding LocalRecordFormatIndex, ElementName=Root, Mode=TwoWay}">
                                                <ComboBoxItem Content="TS/FLV" />
                                                <ComboBoxItem Content="TS/FLV -&gt; MP4" />
                                                <ComboBoxItem Content="TS/FLV -&gt; MKV" />
                                            </ComboBox>
                                        </Grid>
                                    </ui:Grid>
                                </ui:CardExpander.Header>
                                <ui:StackPanel Spacing="8">
                                    <ui:StackPanel Margin="42,0,28,0" Spacing="12">
                                        <CheckBox Content="{I18N RecordFormatAutoRemove}"
                                                  IsChecked="{Binding LocalIsRemoveTs, ElementName=Root, Mode=TwoWay}" />
                                    </ui:StackPanel>
                                </ui:StackPanel>
                            </ui:CardExpander>
                            <ui:Card Padding="14">
                                <ui:Grid MinHeight="54" ColumnDefinitions="Auto,*,Auto">
                                    <ui:FontIcon Grid.Column="0"
                                                 Margin="4,0,18,0"
                                                 VerticalAlignment="Center"
                                                 FontFamily="{DynamicResource SymbolThemeFontFamily}"
                                                 FontSize="22"
                                                 Glyph="{x:Static ui:FontSymbols.Video}" />
                                    <ui:Grid Grid.Column="1" RowDefinitions="Auto,Auto">
                                        <TextBlock Grid.Row="0" Text="{I18N StreamQuality}" />
                                        <TextBlock Grid.Row="1"
                                                   FontSize="11"
                                                   Foreground="{DynamicResource SystemFillColorSolidNeutralBrush}"
                                                   Text="{I18N StreamQuality}" />
                                    </ui:Grid>
                                    <ComboBox Grid.Column="2"
                                              Width="86"
                                              Margin="16,0,0,0"
                                              SelectedIndex="{Binding LocalStreamQualityIndex, ElementName=Root, Mode=TwoWay}">
                                        <ComboBoxItem Content="原画" />
                                        <ComboBoxItem Content="蓝光" />
                                        <ComboBoxItem Content="超清" />
                                        <ComboBoxItem Content="高清" />
                                        <ComboBoxItem Content="标清" />
                                        <ComboBoxItem Content="流畅" />
                                    </ComboBox>
                                </ui:Grid>
                            </ui:Card>
                            <ui:Card Padding="14">
                                <ui:Grid MinHeight="54" ColumnDefinitions="Auto,*,Auto">
                                    <ui:FontIcon Grid.Column="0"
                                                 Margin="4,0,18,0"
                                                 VerticalAlignment="Center"
                                                 FontFamily="{DynamicResource SymbolThemeFontFamily}"
                                                 FontSize="22"
                                                 Glyph="{x:Static ui:FontSymbols.BulletedList}" />
                                    <ui:Grid Grid.Column="1" RowDefinitions="Auto,Auto">
                                        <TextBlock Grid.Row="0" Text="{I18N Segment}" />
                                        <TextBlock Grid.Row="1"
                                                   FontSize="11"
                                                   Foreground="{DynamicResource SystemFillColorSolidNeutralBrush}"
                                                   Text="{I18N SegmentHint}" />
                                    </ui:Grid>
                                    <ui:StackPanel Grid.Column="2"
                                                   Margin="24,0,0,0"
                                                   VerticalAlignment="Center"
                                                   Orientation="Horizontal">
                                        <ui:TextBox Width="112"
                                                    IsEnabled="{Binding LocalIsToSegment, ElementName=Root}"
                                                    Style="{StaticResource MainNumberInputTextBoxStyle}"
                                                    Tag="Decimal"
                                                    Text="{Binding LocalSegmentTimeValue, ElementName=Root, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                    Visibility="{Binding LocalIsToSegment, ElementName=Root, Converter={x:Static c:BoolToVisibilityConverter.Instance}}" />
                                        <ComboBox Width="92"
                                                  Margin="12,0,0,0"
                                                  IsEnabled="{Binding LocalIsToSegment, ElementName=Root}"
                                                  Visibility="{Binding LocalIsToSegment, ElementName=Root, Converter={x:Static c:BoolToVisibilityConverter.Instance}}"
                                                  SelectedIndex="{Binding LocalSegmentTimeUnitIndex, ElementName=Root, Mode=TwoWay}">
                                            <ComboBoxItem Content="{Binding SegmentTimeSecondsText, ElementName=Root}" />
                                            <ComboBoxItem Content="{Binding SegmentTimeMinutesText, ElementName=Root}" />
                                            <ComboBoxItem Content="{Binding SegmentTimeHoursText, ElementName=Root}" />
                                            <ComboBoxItem Content="{Binding SegmentTimeMegabytesText, ElementName=Root}" />
                                            <ComboBoxItem Content="{Binding SegmentTimeGigabytesText, ElementName=Root}" />
                                        </ComboBox>
                                        <ui:ToggleSwitch Margin="24,0,0,0" IsChecked="{Binding LocalIsToSegment, ElementName=Root, Mode=TwoWay}" />
                                    </ui:StackPanel>
                                </ui:Grid>
                            </ui:Card>
                            <ui:CardExpander>
                                <ui:CardExpander.Header>
                                    <ui:Grid ColumnDefinitions="Auto,*,Auto">
                                        <Grid Grid.Column="0" Margin="0,0,12,0">
                                            <TextBlock MinWidth="26"
                                                       Margin="4,0,0,0"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center"
                                                       FontFamily="{DynamicResource SymbolThemeFontFamily}"
                                                       FontSize="18"
                                                       Text="{x:Static ui:FontSymbols.Folder}" />
                                        </Grid>
                                        <ui:Grid Grid.Column="1" RowDefinitions="Auto,Auto">
                                            <TextBlock Grid.Row="0" Text="{I18N ButtonOfSave}" />
                                            <TextBlock Grid.Row="1"
                                                       FontSize="11"
                                                       Foreground="{DynamicResource SystemFillColorSolidNeutralBrush}"
                                                       Text="{I18N SaveFolderHint}" />
                                        </ui:Grid>
                                        <Grid Grid.Column="2" Margin="0,0,12,0" />
                                    </ui:Grid>
                                </ui:CardExpander.Header>
                                <ui:StackPanel Spacing="10">
                                    <ui:Grid Margin="42,0,28,0" ColumnDefinitions="Auto,*,Auto,Auto">
                                        <TextBlock Grid.Column="0"
                                                   VerticalAlignment="Center"
                                                   Text="{I18N SaveFolder}" />
                                        <ui:TextBox Grid.Column="1"
                                                    Margin="8,0,0,0"
                                                    PlaceholderText="downloads"
                                                    Text="{Binding LocalSaveFolder, ElementName=Root, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                        <Button Grid.Column="2"
                                                Margin="8,0,0,0"
                                                Content="{I18N SelectFolder}"
                                                Click="SelectLocalSaveFolderClick" />
                                        <Button Grid.Column="3"
                                                Margin="8,0,0,0"
                                                Content="{I18N OpenFolder}"
                                                Click="OpenLocalSaveFolderClick" />
                                    </ui:Grid>
                                    <ui:Grid Margin="42,0,28,0" ColumnDefinitions="Auto,Auto">
                                        <TextBlock Grid.Column="0"
                                                   VerticalAlignment="Center"
                                                   Text="{I18N SavePathLevel}" />
                                        <ComboBox Grid.Column="1"
                                                  MinWidth="190"
                                                  Margin="8,0,0,0"
                                                  SelectedIndex="{Binding LocalSaveFolderPathLevelIndex, ElementName=Root, Mode=TwoWay}">
                                            <ComboBoxItem Content="{I18N SavePathLevelAuthorDate}" />
                                            <ComboBoxItem Content="{I18N SavePathLevelPlatformAuthorDate}" />
                                        </ComboBox>
                                    </ui:Grid>
                                    <ui:Grid Margin="42,0,28,0" ColumnDefinitions="Auto,Auto">
                                        <TextBlock Grid.Column="0"
                                                   VerticalAlignment="Center"
                                                   Text="视频命名规则" />
                                        <ComboBox Grid.Column="1"
                                                  MinWidth="270"
                                                  Margin="8,0,0,0"
                                                  SelectedIndex="{Binding LocalSaveFileNameRuleIndex, ElementName=Root, Mode=TwoWay}">
                                            <ComboBoxItem Content="{}{主播名}_{录制时间}" />
                                            <ComboBoxItem Content="{}{主播名}_{录制时间}_{分辨率}" />
                                            <ComboBoxItem Content="{}{平台}_{主播名}_{录制时间}" />
                                            <ComboBoxItem Content="{}{平台}_{主播名}_{录制时间}_{分辨率}" />
                                            <ComboBoxItem Content="自定义" />
                                        </ComboBox>
                                    </ui:Grid>
                                    <ui:StackPanel Margin="42,0,28,0"
                                                   Spacing="10"
                                                   Visibility="{Binding IsLocalSaveFileNameRuleCustom, ElementName=Root, Converter={x:Static c:BoolToVisibilityConverter.Instance}}">
                                        <Separator />
                                        <ui:Grid ColumnDefinitions="Auto,*,Auto">
                                            <TextBlock Grid.Column="0"
                                                       VerticalAlignment="Center"
                                                       Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                                       Text="文件名：" />
                                            <Border Grid.Column="1"
                                                    MinHeight="36"
                                                    Margin="8,0,0,0"
                                                    BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
                                                    BorderThickness="0,0,0,1">
                                                <TextBlock VerticalAlignment="Center"
                                                           Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                                           Text="{Binding LocalSaveFileNameCustomRule, ElementName=Root}"
                                                           TextTrimming="CharacterEllipsis" />
                                            </Border>
                                            <Button Grid.Column="2"
                                                    Margin="8,0,0,0"
                                                    Style="{StaticResource MainIconOnlyButtonStyle}"
                                                    Click="DeleteLocalSaveFileNameTokenClick">
                                                <ui:FontIcon FontFamily="{DynamicResource SymbolThemeFontFamily}" Glyph="{x:Static ui:FontSymbols.CalculatorMultiply}" />
                                            </Button>
                                        </ui:Grid>
                                        <ui:Grid ColumnDefinitions="Auto,*,Auto,*,Auto,*,Auto,*,Auto,*,Auto">
                                            <Button Grid.Column="0" Style="{StaticResource MainNameTokenButtonStyle}" Content="主播名" Tag="{}{主播名}" Click="AppendLocalSaveFileNameTokenClick" />
                                            <Button Grid.Column="2" Style="{StaticResource MainNameTokenButtonStyle}" Content="主播uid" Tag="{}{主播uid}" Click="AppendLocalSaveFileNameTokenClick" />
                                            <Button Grid.Column="4" Style="{StaticResource MainNameTokenButtonStyle}" Content="平台" Tag="{}{平台}" Click="AppendLocalSaveFileNameTokenClick" />
                                            <Button Grid.Column="6" Style="{StaticResource MainNameTokenButtonStyle}" Content="录制时间" Tag="{}{录制时间}" Click="AppendLocalSaveFileNameTokenClick" />
                                            <Button Grid.Column="8" Style="{StaticResource MainNameTokenButtonStyle}" Content="分辨率" Tag="{}{分辨率}" Click="AppendLocalSaveFileNameTokenClick" />
                                            <Button Grid.Column="10" Style="{StaticResource MainDangerAccentButtonStyle}" Padding="14,0" Content="重置" Click="ResetLocalSaveFileNameRuleClick" />
                                        </ui:Grid>
                                    </ui:StackPanel>
                                </ui:StackPanel>
                            </ui:CardExpander>
                        </ui:StackPanel>
                    </ScrollViewer>
                    <ui:StackPanel Grid.Row="2"
                                   HorizontalAlignment="Right"
                                   Orientation="Horizontal"
                                   Spacing="8">
                        <Button MinWidth="92"
                                Background="{DynamicResource ControlFillColorDefaultBrush}"
                                BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
                                Content="{I18N ButtonOfCancel}"
                                Click="CloseFloatingPanelsClick" />
                        <Button MinWidth="92"
                                Style="{StaticResource MainAccentButtonStyle}"
                                Content="{I18N ButtonOfSave}"
                                Click="SaveLocalSettingsClick" />
                    </ui:StackPanel>
                </ui:Grid>
            </Border>
            <Border x:Name="AboutFlyout"
                    Width="540"
                    Padding="18"
                    Style="{StaticResource MainFlyoutBorderStyle}"
                    Visibility="Collapsed">
                <ui:Grid RowDefinitions="Auto,Auto,Auto">
                    <ui:Grid Grid.Row="0" ColumnDefinitions="Auto,*,Auto">
                        <Image Grid.Column="0"
                               Height="44"
                               Source="pack://application:,,,/Assets/Favicon.png" />
                        <ui:StackPanel Grid.Column="1"
                                       Margin="12,0,0,0"
                                       VerticalAlignment="Center"
                                       Spacing="3">
                            <TextBlock Style="{StaticResource MainFlyoutTitleStyle}" Text="{x:Static local:AppConfig.DisplayName}" />
                            <TextBlock Style="{StaticResource MainFlyoutCaptionStyle}" Text="{x:Static local:AppConfig.EnglishName}" />
                            <TextBlock Style="{StaticResource MainFlyoutCaptionStyle}" Text="{x:Static local:AppConfig.Version}" />
                        </ui:StackPanel>
                        <Button Grid.Column="2"
                                Click="CloseFloatingPanelsClick"
                                Style="{StaticResource MainFlyoutCloseButtonStyle}">
                            <ui:FontIcon FontFamily="{DynamicResource SymbolThemeFontFamily}"
                                         FontSize="12"
                                         Glyph="{x:Static ui:FontSymbols.CalculatorMultiply}" />
                        </Button>
                    </ui:Grid>
                    <TextBlock Grid.Row="1"
                               Margin="0,18,0,8"
                               FontWeight="SemiBold"
                               Text="软件仓库" />
                    <Border Grid.Row="2"
                            Padding="12"
                            Background="#0A000000"
                            BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
                            BorderThickness="1"
                            CornerRadius="8">
                        <ui:StackPanel Spacing="8">
                            <ui:HyperlinkButton Command="{Binding OpenHyperlinkCommand}" CommandParameter="https://github.com/qzj1472/MPLR" Content="qzj1472/MPLR" Cursor="Hand" />
                            <Separator />
                            <TextBlock FontWeight="SemiBold" Text="组件与库" />
                            <ScrollViewer MaxHeight="260"
                                          HorizontalScrollBarVisibility="Disabled"
                                          VerticalScrollBarVisibility="Auto">
                                <ui:StackPanel Spacing="6">
                                    <ui:HyperlinkButton Command="{Binding OpenHyperlinkCommand}" CommandParameter="https://github.com/emako/TiktokLiveRec" Content="emako/TiktokLiveRec" Cursor="Hand" />
                                    <ui:HyperlinkButton Command="{Binding OpenHyperlinkCommand}" CommandParameter="https://github.com/ihmily/DouyinLiveRecorder" Content="DouyinLiveRecorder" Cursor="Hand" />
                                    <ui:HyperlinkButton Command="{Binding OpenHyperlinkCommand}" CommandParameter="https://github.com/lepoco/wpfui" Content="WPF-UI / WPF-UI.Violeta" Cursor="Hand" />
                                    <ui:HyperlinkButton Command="{Binding OpenHyperlinkCommand}" CommandParameter="https://learn.microsoft.com/dotnet/communitytoolkit/mvvm/" Content="CommunityToolkit.Mvvm" Cursor="Hand" />
                                    <ui:HyperlinkButton Command="{Binding OpenHyperlinkCommand}" CommandParameter="https://www.nuget.org/packages/Fischless.Configuration" Content="Fischless.Configuration" Cursor="Hand" />
                                    <ui:HyperlinkButton Command="{Binding OpenHyperlinkCommand}" CommandParameter="https://restsharp.dev/" Content="RestSharp" Cursor="Hand" />
                                    <ui:HyperlinkButton Command="{Binding OpenHyperlinkCommand}" CommandParameter="https://www.newtonsoft.com/json" Content="Newtonsoft.Json" Cursor="Hand" />
                                    <ui:HyperlinkButton Command="{Binding OpenHyperlinkCommand}" CommandParameter="https://github.com/dahall/Vanara" Content="Vanara.PInvoke" Cursor="Hand" />
                                    <ui:HyperlinkButton Command="{Binding OpenHyperlinkCommand}" CommandParameter="https://mediaarea.net/en/MediaInfo" Content="MediaInfoDLL" Cursor="Hand" />
                                    <ui:HyperlinkButton Command="{Binding OpenHyperlinkCommand}" CommandParameter="https://github.com/ksineni/FluentWPF/tree/master/LottieSharp" Content="LottieSharp" Cursor="Hand" />
                                    <ui:HyperlinkButton Command="{Binding OpenHyperlinkCommand}" CommandParameter="https://github.com/CommunityToolkit/WindowsCommunityToolkit" Content="Microsoft.Toolkit.Uwp.Notifications" Cursor="Hand" />
                                    <ui:HyperlinkButton Command="{Binding OpenHyperlinkCommand}" CommandParameter="https://github.com/naudio/NAudio" Content="NAudio" Cursor="Hand" />
                                    <ui:HyperlinkButton Command="{Binding OpenHyperlinkCommand}" CommandParameter="https://ffmpeg.org/" Content="FFmpeg" Cursor="Hand" />
                                </ui:StackPanel>
                            </ScrollViewer>
                        </ui:StackPanel>
                    </Border>
                </ui:Grid>
            </Border>
            <Border x:Name="ExitStrategyFlyout"
                    Width="404"
                    Padding="18"
                    Style="{StaticResource MainFlyoutBorderStyle}"
                    Visibility="Collapsed">
                <ui:Grid RowDefinitions="Auto,Auto,Auto">
                    <ui:Grid Grid.Row="0" ColumnDefinitions="Auto,*">
                        <ui:FontIcon Grid.Column="0"
                                     Margin="0,0,12,0"
                                     VerticalAlignment="Center"
                                     FontFamily="{DynamicResource SymbolThemeFontFamily}"
                                     FontSize="20"
                                     Glyph="{x:Static ui:FontSymbols.PowerButton}" />
                        <TextBlock Grid.Column="1"
                                   Style="{StaticResource MainFlyoutTitleStyle}"
                                   Text="退出程序" />
                    </ui:Grid>
                    <ui:StackPanel Grid.Row="1"
                                   Margin="0,18,0,20"
                                   Spacing="10">
                        <TextBlock Style="{StaticResource MainFlyoutCaptionStyle}" Text="请选择点击关闭按钮后的处理方式。" />
                        <CheckBox x:Name="ExitStrategyRememberCheckBox" Content="下次不再询问" />
                    </ui:StackPanel>
                    <ui:StackPanel Grid.Row="2"
                                   HorizontalAlignment="Right"
                                   Orientation="Horizontal"
                                   Spacing="12">
                        <Button MinWidth="104"
                                Content="取消"
                                Click="CancelExitClick" />
                        <Button MinWidth="104"
                                Margin="12,0,0,0"
                                Style="{StaticResource MainDangerAccentButtonStyle}"
                                Content="直接退出"
                                Click="DirectExitClick" />
                        <Button MinWidth="92"
                                Content="最小化"
                                Click="MinimizeToTrayExitClick" />
                    </ui:StackPanel>
                </ui:Grid>
            </Border>
            <Border x:Name="AutoShutdownPromptFlyout"
                    Width="620"
                    Padding="20"
                    Style="{StaticResource MainFlyoutBorderStyle}"
                    Visibility="Collapsed">
                <ui:Grid RowDefinitions="Auto,Auto,Auto,Auto">
                    <ui:Grid Grid.Row="0" ColumnDefinitions="Auto,*">
                        <ui:FontIcon Grid.Column="0"
                                     Margin="0,0,12,0"
                                     VerticalAlignment="Center"
                                     FontFamily="{DynamicResource SymbolThemeFontFamily}"
                                     FontSize="20"
                                     Glyph="{x:Static ui:FontSymbols.PowerButton}" />
                        <TextBlock Grid.Column="1"
                                   Style="{StaticResource MainFlyoutTitleStyle}"
                                   Text="{I18N AutoShutdown}" />
                    </ui:Grid>
                    <TextBlock Grid.Row="1"
                               Margin="0,18,0,18"
                               FontSize="13"
                               Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                               TextWrapping="Wrap"
                               Text="录制已结束，有转码的话我们会尽快完成转码，当到了指定时间没有转码完成我们会保存已经转码部分。如果你希望完成转码再关闭，可以在设置内选择‘转码完关闭’，或者选择下方的‘转码完关闭’按钮" />
                    <ui:StackPanel Grid.Row="2"
                                   HorizontalAlignment="Right"
                                   Orientation="Horizontal"
                                   Spacing="12">
                        <Button MinWidth="104"
                                Content="取消关闭"
                                Click="CancelAutoShutdownPromptClick" />
                        <Button MinWidth="104"
                                Style="{StaticResource MainDangerAccentButtonStyle}"
                                Content="现在关闭"
                                Click="ShutdownNowPromptClick" />
                        <Button MinWidth="116"
                                Content="转码完关闭"
                                Click="ShutdownAfterTranscodePromptClick" />
                    </ui:StackPanel>
                    <Button Grid.Row="3"
                            Height="38"
                            Margin="0,18,0,0"
                            HorizontalAlignment="Stretch"
                            Style="{StaticResource MainAccentButtonStyle}"
                            Content="我知道了"
                            Click="CloseAutoShutdownPromptClick" />
                </ui:Grid>
            </Border>
        </Canvas>
        <Grid>
            <ui:TitleBar Title="{I18N Title}" ShowMaximize="True">
                <ui:TitleBar.Icon>
                    <ui:ImageIcon Source="pack://application:,,,/Assets/Favicon.png" />
                </ui:TitleBar.Icon>
            </ui:TitleBar>
        </Grid>
    </Grid>
</ui:FluentWindow>


