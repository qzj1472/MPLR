<ui:FluentWindow x:Class="TiktokLiveRec.Views.MainWindow"
                 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:b="http://schemas.github.com/computedbehaviors/2024/xaml"
                 xmlns:c="http://schemas.github.com/computedconverters/2024/xaml"
                 xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                 xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
                 xmlns:local="clr-namespace:TiktokLiveRec"
                 xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                 xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
                 xmlns:vio="http://schemas.lepo.co/wpfui/2022/xaml/violeta"
                 xmlns:views="clr-namespace:TiktokLiveRec.Views"
                 x:Name="Root"
                 Title="{I18N Title}"
                 Width="1290"
                 Height="900"
                 d:Background="#FF101010"
                 ExtendsContentIntoTitleBar="True"
                 WindowBackdropType="Mica"
                 WindowStartupLocation="CenterScreen"
                 mc:Ignorable="d">
    <ui:FluentWindow.Resources>
        <Style x:Key="StatusIconButtonStyle" TargetType="{x:Type Button}">
            <Setter Property="Width" Value="18" />
            <Setter Property="Height" Value="18" />
            <Setter Property="MinWidth" Value="18" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Cursor" Value="Hand" />
        </Style>
        <Style x:Key="MainFlyoutBorderStyle" TargetType="{x:Type Border}">
            <Setter Property="Background" Value="{DynamicResource SolidBackgroundFillColorBaseBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource SurfaceStrokeColorFlyoutBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="10" />
            <Setter Property="SnapsToDevicePixels" Value="True" />
        </Style>
        <Style x:Key="MainFlyoutTitleStyle" TargetType="{x:Type TextBlock}">
            <Setter Property="FontSize" Value="16" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>
        <Style x:Key="MainFlyoutCaptionStyle" TargetType="{x:Type TextBlock}">
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Foreground" Value="{DynamicResource TextFillColorSecondaryBrush}" />
            <Setter Property="TextWrapping" Value="Wrap" />
        </Style>
        <Style x:Key="MainFlyoutCloseButtonStyle" TargetType="{x:Type Button}" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Width" Value="32" />
            <Setter Property="Height" Value="32" />
            <Setter Property="MinWidth" Value="32" />
            <Setter Property="Padding" Value="0" />
        </Style>
        <Style x:Key="MainFlyoutOptionButtonStyle" TargetType="{x:Type Button}" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Height" Value="34" />
            <Setter Property="HorizontalContentAlignment" Value="Left" />
            <Setter Property="Padding" Value="12,0" />
        </Style>
        <Style x:Key="MainFlyoutTextButtonStyle" TargetType="{x:Type Button}" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Padding" Value="4,0" />
            <Setter Property="MinWidth" Value="0" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="Cursor" Value="Hand" />
        </Style>
    </ui:FluentWindow.Resources>
    <Grid>
        <ui:Grid x:Name="MainContentRoot" Margin="8,42,8,8" RowDefinitions="Auto,*,Auto">
            <ui:Grid Grid.Row="0" ColumnDefinitions="Auto,*,Auto">
                <ui:StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="8">
                    <Button MinWidth="72"
                            Background="{DynamicResource SystemAccentColorPrimaryBrush}"
                            BorderBrush="{DynamicResource SystemAccentColorPrimaryBrush}"
                            Foreground="White"
                            Click="OpenAddRoomFlyoutClick">
                        <Button.Content>
                            <ui:StackPanel Orientation="Horizontal" Spacing="8">
                                <ui:FontIcon FontFamily="{DynamicResource SymbolThemeFontFamily}" Glyph="{x:Static ui:FontSymbols.Add}" />
                                <TextBlock Text="{I18N ToolbarNew}" />
                            </ui:StackPanel>
                        </Button.Content>
                    </Button>
                    <Button MinWidth="72" Command="{Binding ToggleMonitorCommand}">
                        <Button.Content>
                            <ui:StackPanel Orientation="Horizontal" Spacing="8">
                                <ui:FontIcon FontFamily="{DynamicResource SymbolThemeFontFamily}" Glyph="{x:Static ui:FontSymbols.Radar}" />
                                <TextBlock Text="{I18N ToolbarMonitor}" />
                            </ui:StackPanel>
                        </Button.Content>
                    </Button>
                    <Button MinWidth="72" Command="{Binding ToggleRecordCommand}">
                        <Button.Content>
                            <ui:StackPanel Orientation="Horizontal" Spacing="8">
                                <ui:FontIcon FontFamily="{DynamicResource SymbolThemeFontFamily}" Glyph="{x:Static ui:FontSymbols.Record}" />
                                <TextBlock Text="{I18N ToolbarRecord}" />
                            </ui:StackPanel>
                        </Button.Content>
                    </Button>
                    <Button MinWidth="72" Command="{Binding OpenTranscodeSettingsCommand}">
                        <Button.Content>
                            <ui:StackPanel Orientation="Horizontal" Spacing="8">
                                <ui:FontIcon FontFamily="{DynamicResource SymbolThemeFontFamily}" Glyph="{x:Static ui:FontSymbols.Trim}" />
                                <TextBlock Text="{I18N ToolbarTranscode}" />
                            </ui:StackPanel>
                        </Button.Content>
                    </Button>
                    <Button MinWidth="72" Command="{Binding OpenSettingsDialogCommand}">
                        <Button.Content>
                            <ui:StackPanel Orientation="Horizontal" Spacing="8">
                                <ui:FontIcon FontFamily="{DynamicResource SymbolThemeFontFamily}" Glyph="{x:Static ui:FontSymbols.Settings}" />
                                <TextBlock Text="{I18N ButtonOfSettings}" />
                            </ui:StackPanel>
                        </Button.Content>
                    </Button>
                    <Button MinWidth="72" Click="OpenAboutFlyoutClick">
                        <Button.Content>
                            <ui:StackPanel Orientation="Horizontal" Spacing="8">
                                <ui:FontIcon FontFamily="{DynamicResource SymbolThemeFontFamily}" Glyph="{x:Static ui:FontSymbols.Info}" />
                                <TextBlock Text="{I18N About}" />
                            </ui:StackPanel>
                        </Button.Content>
                    </Button>
                    <Button MinWidth="72" Command="{Binding ExitApplicationCommand}">
                        <Button.Content>
                            <ui:StackPanel Orientation="Horizontal" Spacing="8">
                                <ui:FontIcon FontFamily="{DynamicResource SymbolThemeFontFamily}" Glyph="{x:Static ui:FontSymbols.PowerButton}" />
                                <TextBlock Text="{I18N ToolbarExit}" />
                            </ui:StackPanel>
                        </Button.Content>
                    </Button>
                </ui:StackPanel>
                <ui:StackPanel Grid.Column="2"
                               HorizontalAlignment="Right"
                               Orientation="Horizontal"
                               Spacing="8">
                    <Button MinWidth="80" Command="{Binding OpenSaveFolderCommand}">
                        <Button.Content>
                            <ui:StackPanel Orientation="Horizontal" Spacing="8">
                                <ui:FontIcon FontFamily="{DynamicResource SymbolThemeFontFamily}" Glyph="{x:Static ui:FontSymbols.FolderOpen}" />
                                <TextBlock Text="{I18N SaveFolder}" />
                            </ui:StackPanel>
                        </Button.Content>
                    </Button>
                </ui:StackPanel>
            </ui:Grid>
            <ui:Grid Grid.Row="1"
                     Margin="0,8,0,0"
                     ColumnDefinitions="13*,7*">
                <ui:Grid.Resources>
                    <c:ValueConverterGroup x:Key="NotZeroIntToToVisibilityConverter">
                        <c:IntToBoolConverter TrueValue="0" />
                        <c:BoolToVisibilityConverter />
                    </c:ValueConverterGroup>
                    <Style x:Key="OperationButtonStyle" TargetType="{x:Type Button}" BasedOn="{StaticResource {x:Type Button}}">
                        <Setter Property="Height" Value="34" />
                        <Setter Property="MinWidth" Value="78" />
                        <Setter Property="Padding" Value="10,0" />
                        <Setter Property="Margin" Value="0,0,8,8" />
                    </Style>
                    <Style x:Key="InfoIconButtonStyle" TargetType="{x:Type Button}" BasedOn="{StaticResource {x:Type Button}}">
                        <Setter Property="Width" Value="20" />
                        <Setter Property="Height" Value="26" />
                        <Setter Property="MinWidth" Value="20" />
                        <Setter Property="MaxWidth" Value="20" />
                        <Setter Property="MinHeight" Value="24" />
                        <Setter Property="MaxHeight" Value="26" />
                        <Setter Property="Padding" Value="0" />
                        <Setter Property="BorderBrush" Value="{DynamicResource ControlStrokeColorDefaultBrush}" />
                        <Setter Property="BorderThickness" Value="1" />
                        <Setter Property="Background" Value="{DynamicResource ControlFillColorDefaultBrush}" />
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="{x:Type Button}">
                                    <Border x:Name="RootBorder"
                                            Background="{TemplateBinding Background}"
                                            BorderBrush="{TemplateBinding BorderBrush}"
                                            BorderThickness="{TemplateBinding BorderThickness}"
                                            CornerRadius="5">
                                        <ContentPresenter HorizontalAlignment="Center"
                                                          VerticalAlignment="Center"
                                                          RecognizesAccessKey="True" />
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="RootBorder" Property="Background" Value="{DynamicResource ControlFillColorSecondaryBrush}" />
                                        </Trigger>
                                        <Trigger Property="IsPressed" Value="True">
                                            <Setter TargetName="RootBorder" Property="Background" Value="{DynamicResource ControlFillColorTertiaryBrush}" />
                                        </Trigger>
                                        <Trigger Property="IsEnabled" Value="False">
                                            <Setter TargetName="RootBorder" Property="Opacity" Value="0.5" />
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                    <Style x:Key="RoomCardListBoxStyle" TargetType="{x:Type ListBox}">
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="{x:Type ListBox}">
                                    <ScrollViewer x:Name="RoomCardScrollViewer"
                                                  Padding="{TemplateBinding Padding}"
                                                  Focusable="False"
                                                  HorizontalScrollBarVisibility="{TemplateBinding ScrollViewer.HorizontalScrollBarVisibility}"
                                                  VerticalScrollBarVisibility="{TemplateBinding ScrollViewer.VerticalScrollBarVisibility}">
                                        <ScrollViewer.Template>
                                            <ControlTemplate TargetType="{x:Type ScrollViewer}">
                                                <Grid>
                                                    <ScrollContentPresenter CanContentScroll="{TemplateBinding CanContentScroll}"
                                                                            Content="{TemplateBinding Content}"
                                                                            ContentTemplate="{TemplateBinding ContentTemplate}" />
                                                    <ScrollBar x:Name="PART_VerticalScrollBar"
                                                               Width="8"
                                                               Margin="0,0,-2,0"
                                                               HorizontalAlignment="Right"
                                                               Maximum="{TemplateBinding ScrollableHeight}"
                                                               Orientation="Vertical"
                                                               ViewportSize="{TemplateBinding ViewportHeight}"
                                                               Value="{TemplateBinding VerticalOffset}"
                                                               Visibility="{TemplateBinding ComputedVerticalScrollBarVisibility}" />
                                                </Grid>
                                            </ControlTemplate>
                                        </ScrollViewer.Template>
                                        <ItemsPresenter />
                                    </ScrollViewer>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </ui:Grid.Resources>
                <ui:BitmapIcon Grid.ColumnSpan="2"
                               Width="100"
                               Height="100"
                               Margin="8"
                               HorizontalAlignment="Right"
                               VerticalAlignment="Bottom"
                               Opacity="0.35"
                               IsHitTestVisible="False"
                               ShowAsMonochrome="True"
                               UriSource="pack://application:,,,/Assets/Background.png" />
                <Border Grid.Column="0"
                        Padding="10"
                        Background="#0E000000"
                        BorderBrush="{DynamicResource SystemFillColorSolidNeutralBrush}"
                        BorderThickness="1"
                        CornerRadius="8"
                        ClipToBounds="False">
                    <Grid ClipToBounds="False">
                        <ListBox x:Name="RoomCardList"
                                 Background="Transparent"
                                 BorderThickness="0"
                                 ClipToBounds="False"
                                 ItemsSource="{Binding RoomStatuses}"
                                 Padding="0"
                                 Style="{StaticResource RoomCardListBoxStyle}"
                                 PreviewMouseLeftButtonDown="RoomCardListPreviewMouseLeftButtonDown"
                                 PreviewMouseLeftButtonUp="RoomCardListPreviewMouseLeftButtonUp"
                                 PreviewMouseMove="RoomCardListPreviewMouseMove"
                                 PreviewMouseRightButtonDown="RoomCardListPreviewMouseRightButtonDown"
                                 MouseDoubleClick="RoomCardListMouseDoubleClick"
                                 Loaded="RoomCardListLoaded"
                                 SizeChanged="RoomCardListSizeChanged"
                                 LostMouseCapture="RoomCardListLostMouseCapture"
                                 ScrollViewer.CanContentScroll="True"
                                 ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                 ScrollViewer.VerticalScrollBarVisibility="Auto"
                                 SelectedItem="{Binding SelectedItem, Mode=TwoWay}">
                            <ListBox.ContextMenu>
                                <ContextMenu DataContext="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource Self}}">
                                    <MenuItem Header="{I18N CardSort}">
                                        <MenuItem Header="{I18N CardSortByName}" Command="{Binding SortRoomsByNameCommand}" />
                                        <MenuItem Header="{I18N CardSortByAddedAt}" Command="{Binding SortRoomsByAddedAtCommand}" />
                                    </MenuItem>
                                    <MenuItem Header="{I18N CardSize}">
                                        <MenuItem x:Name="RoomCardLargeMenuItem" Header="{I18N CardSizeLarge}" Click="SetRoomCardLargeClick" />
                                        <MenuItem Header="{I18N CardSizeMedium}" Click="SetRoomCardMediumClick" />
                                        <MenuItem Header="{I18N CardSizeSmall}" Click="SetRoomCardSmallClick" />
                                    </MenuItem>
                                    <Separator />
                                    <MenuItem Header="{I18N CardRefresh}" Command="{Binding RefreshRoomCardsCommand}" />
                                    <MenuItem Header="{I18N CardEdit}"
                                              Command="{Binding ToggleCardEditModeCommand}"
                                              IsCheckable="True"
                                              IsChecked="{Binding IsCardEditMode, Mode=OneWay}" />
                                </ContextMenu>
                            </ListBox.ContextMenu>
                            <ListBox.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel IsItemsHost="True"
                                               Width="{Binding RoomCardPanelWidth, RelativeSource={RelativeSource AncestorType={x:Type views:MainWindow}}}"
                                               HorizontalAlignment="Center"
                                               ItemWidth="{Binding RoomCardItemWidth, RelativeSource={RelativeSource AncestorType={x:Type views:MainWindow}}}"
                                               ItemHeight="{Binding RoomCardItemHeight, RelativeSource={RelativeSource AncestorType={x:Type views:MainWindow}}}" />
                                </ItemsPanelTemplate>
                            </ListBox.ItemsPanel>
                            <ListBox.ItemContainerStyle>
                                <Style TargetType="{x:Type ListBoxItem}">
                                    <Setter Property="HorizontalContentAlignment" Value="Center" />
                                    <Setter Property="VerticalContentAlignment" Value="Center" />
                                    <Setter Property="Margin" Value="0" />
                                    <Setter Property="Padding" Value="0" />
                                    <Setter Property="Background" Value="Transparent" />
                                    <Setter Property="BorderBrush" Value="Transparent" />
                                    <Setter Property="BorderThickness" Value="0" />
                                    <Setter Property="ClipToBounds" Value="False" />
                                    <Setter Property="FocusVisualStyle" Value="{x:Null}" />
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="{x:Type ListBoxItem}">
                                                <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                                                  VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                                                  SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}" />
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </ListBox.ItemContainerStyle>
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Border x:Name="RoomCardShell"
                                            Width="{Binding RoomCardWidth, RelativeSource={RelativeSource AncestorType={x:Type views:MainWindow}}}"
                                            Height="{Binding RoomCardHeight, RelativeSource={RelativeSource AncestorType={x:Type views:MainWindow}}}"
                                            Margin="{Binding RoomCardMargin, RelativeSource={RelativeSource AncestorType={x:Type views:MainWindow}}}"
                                            Padding="{Binding RoomCardPadding, RelativeSource={RelativeSource AncestorType={x:Type views:MainWindow}}}"
                                            Background="#12000000"
                                            BorderBrush="{DynamicResource SystemFillColorSolidNeutralBrush}"
                                            BorderThickness="1"
                                            CornerRadius="8"
                                            TextElement.Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                                            RenderTransformOrigin="0.5,0.5"
                                            SnapsToDevicePixels="True"
                                            Tag="{Binding DataContext, RelativeSource={RelativeSource AncestorType={x:Type ListBox}}}">
                                        <Border.RenderTransform>
                                            <RotateTransform x:Name="RoomCardAngle" Angle="0" />
                                        </Border.RenderTransform>
                                        <Border.ContextMenu>
                                            <ContextMenu DataContext="{Binding PlacementTarget.Tag, RelativeSource={RelativeSource Self}}">
                                                <MenuItem Header="{I18N Preview}" Command="{Binding PreviewCommand}">
                                                    <MenuItem.Icon>
                                                        <ui:FontIcon FontFamily="{DynamicResource SymbolThemeFontFamily}" Glyph="{x:Static ui:FontSymbols.Play}" />
                                                    </MenuItem.Icon>
                                                </MenuItem>
                                                <MenuItem Header="{I18N GotoLiveRoom}" Command="{Binding GotoRoomUrlCommand}">
                                                    <MenuItem.Icon>
                                                        <ui:FontIcon FontFamily="{DynamicResource SymbolThemeFontFamily}" Glyph="{x:Static ui:FontSymbols.OpenInNewWindow}" />
                                                    </MenuItem.Icon>
                                                </MenuItem>
                                                <MenuItem Header="{I18N SaveFolder}" Command="{Binding OpenSaveFolderCommand}">
                                                    <MenuItem.Icon>
                                                        <ui:FontIcon FontFamily="{DynamicResource SymbolThemeFontFamily}" Glyph="{x:Static ui:FontSymbols.FolderOpen}" />
                                                    </MenuItem.Icon>
                                                </MenuItem>
                                                <Separator />
                                                <MenuItem Header="{I18N RowUpRoom}" Command="{Binding RowUpRoomUrlCommand}">
                                                    <MenuItem.Icon>
                                                        <ui:FontIcon FontFamily="{DynamicResource SymbolThemeFontFamily}" Glyph="{x:Static ui:FontSymbols.ChevronUp}" />
                                                    </MenuItem.Icon>
                                                </MenuItem>
                                                <MenuItem Header="{I18N RowDownRoom}" Command="{Binding RowDownRoomUrlCommand}">
                                                    <MenuItem.Icon>
                                                        <ui:FontIcon FontFamily="{DynamicResource SymbolThemeFontFamily}" Glyph="{x:Static ui:FontSymbols.ChevronDown}" />
                                                    </MenuItem.Icon>
                                                </MenuItem>
                                                <MenuItem Header="{I18N StopRecord}" Command="{Binding StopRecordCommand}">
                                                    <MenuItem.Icon>
                                                        <ui:FontIcon FontFamily="{DynamicResource SymbolThemeFontFamily}" Glyph="{x:Static ui:FontSymbols.Stop}" />
                                                    </MenuItem.Icon>
                                                </MenuItem>
                                                <Separator />
                                                <MenuItem Header="{I18N LiveNotification}"
                                                          Command="{Binding IsToNotifyCommand}"
                                                          IsCheckable="True"
                                                          IsChecked="{Binding SelectedItem.IsToNotify, Mode=TwoWay}" />
                                                <MenuItem Header="{I18N EnableRecord}"
                                                          Command="{Binding IsToRecordCommand}"
                                                          IsCheckable="True"
                                                          IsChecked="{Binding SelectedItem.IsToRecord, Mode=TwoWay}" />
                                                <Separator />
                                                <MenuItem Header="{I18N RemoveRoom}" Command="{Binding RemoveRoomUrlCommand}">
                                                    <MenuItem.Icon>
                                                        <ui:FontIcon FontFamily="{DynamicResource SymbolThemeFontFamily}" Glyph="{x:Static ui:FontSymbols.CalculatorMultiply}" />
                                                    </MenuItem.Icon>
                                                </MenuItem>
                                            </ContextMenu>
                                        </Border.ContextMenu>
                                        <Grid ClipToBounds="False">
                                            <Border x:Name="RoomCardFlashOverlay"
                                                    Background="White"
                                                    CornerRadius="8"
                                                    Panel.ZIndex="2"
                                                    IsHitTestVisible="False"
                                                    Opacity="0" />
                                            <ui:Grid RowDefinitions="Auto,*,Auto">
                                                <Grid Grid.Row="0" ClipToBounds="False">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="{Binding RoomCardHeaderColumnWidth, RelativeSource={RelativeSource AncestorType={x:Type views:MainWindow}}}" />
                                                    <ColumnDefinition Width="*" />
                                                </Grid.ColumnDefinitions>
                                                <Grid Width="{Binding RoomCardAvatarContainerSize, RelativeSource={RelativeSource AncestorType={x:Type views:MainWindow}}}"
                                                      Height="{Binding RoomCardAvatarContainerSize, RelativeSource={RelativeSource AncestorType={x:Type views:MainWindow}}}"
                                                      HorizontalAlignment="Left"
                                                      VerticalAlignment="Top"
                                                      Margin="{Binding RoomCardAvatarMargin, RelativeSource={RelativeSource AncestorType={x:Type views:MainWindow}}}"
                                                      ClipToBounds="False">
                                                    <Ellipse Width="{Binding RoomCardAvatarSize, RelativeSource={RelativeSource AncestorType={x:Type views:MainWindow}}}"
                                                             Height="{Binding RoomCardAvatarSize, RelativeSource={RelativeSource AncestorType={x:Type views:MainWindow}}}"
                                                             HorizontalAlignment="Center"
                                                             VerticalAlignment="Center"
                                                             Fill="#18000000" />
                                                    <Ellipse x:Name="RoomCardAvatarImage"
                                                             Width="{Binding RoomCardAvatarSize, RelativeSource={RelativeSource AncestorType={x:Type views:MainWindow}}}"
                                                             Height="{Binding RoomCardAvatarSize, RelativeSource={RelativeSource AncestorType={x:Type views:MainWindow}}}"
                                                             HorizontalAlignment="Center"
                                                             VerticalAlignment="Center"
                                                             RenderOptions.BitmapScalingMode="HighQuality"
                                                             SnapsToDevicePixels="True">
                                                        <Ellipse.Fill>
                                                            <ImageBrush ImageSource="{Binding AvatarDisplaySource}" Stretch="UniformToFill" />
                                                        </Ellipse.Fill>
                                                    </Ellipse>
                                                    <TextBlock x:Name="RoomCardAvatarPlaceholder"
                                                               FontFamily="Segoe MDL2 Assets"
                                                               FontSize="{Binding RoomCardAvatarIconSize, RelativeSource={RelativeSource AncestorType={x:Type views:MainWindow}}}"
                                                               Text="&#xE77B;"
                                                               HorizontalAlignment="Center"
                                                               VerticalAlignment="Center"
                                                               Visibility="Collapsed" />
                                                </Grid>
                                               <ui:StackPanel Grid.Column="1"
                                                               VerticalAlignment="Center"
                                                               Spacing="2">
                                                    <TextBlock FontSize="{Binding RoomCardNameFontSize, RelativeSource={RelativeSource AncestorType={x:Type views:MainWindow}}}"
                                                               FontWeight="SemiBold"
                                                               Text="{Binding NickName}"
                                                               TextTrimming="CharacterEllipsis" />
                                                    <ui:StackPanel Orientation="Horizontal" Spacing="4">
                                                        <Border Width="{Binding RoomCardPlatformFontSize, RelativeSource={RelativeSource AncestorType={x:Type views:MainWindow}}}"
                                                                Height="{Binding RoomCardPlatformFontSize, RelativeSource={RelativeSource AncestorType={x:Type views:MainWindow}}}"
                                                                CornerRadius="99"
                                                                RenderOptions.BitmapScalingMode="HighQuality">
                                                            <Border.Background>
                                                                <ImageBrush ImageSource="{Binding PlatformIconSource}" Stretch="UniformToFill" />
                                                            </Border.Background>
                                                        </Border>
                                                        <TextBlock FontSize="{Binding RoomCardPlatformFontSize, RelativeSource={RelativeSource AncestorType={x:Type views:MainWindow}}}"
                                                                   Opacity="0.62"
                                                                   Text="{Binding PlatformDisplayName}"
                                                                   TextTrimming="CharacterEllipsis" />
                                                    </ui:StackPanel>
                                                </ui:StackPanel>
                                                </Grid>
                                                <TextBlock Grid.Row="1"
                                                       Margin="0,5,0,0"
                                                       FontSize="{Binding RoomCardTitleFontSize, RelativeSource={RelativeSource AncestorType={x:Type views:MainWindow}}}"
                                                       LineHeight="{Binding RoomCardTitleLineHeight, RelativeSource={RelativeSource AncestorType={x:Type views:MainWindow}}}"
                                                       MaxHeight="{Binding RoomCardTitleMaxHeight, RelativeSource={RelativeSource AncestorType={x:Type views:MainWindow}}}"
                                                       Opacity="0.72"
                                                       Text="{Binding Title}"
                                                       TextTrimming="CharacterEllipsis"
                                                       TextWrapping="Wrap"
                                                       Visibility="{Binding RoomCardTitleVisibility, RelativeSource={RelativeSource AncestorType={x:Type views:MainWindow}}}" />
                                                <ui:Grid Grid.Row="2"
                                                     Margin="0,6,0,0"
                                                     VerticalAlignment="Bottom"
                                                     ColumnDefinitions="*,*">
                                                <Border Grid.Column="0"
                                                        Margin="0,0,4,0"
                                                        Height="{Binding RoomCardChipMinHeight, RelativeSource={RelativeSource AncestorType={x:Type views:MainWindow}}}"
                                                        Padding="{Binding RoomCardChipPadding, RelativeSource={RelativeSource AncestorType={x:Type views:MainWindow}}}"
                                                        Background="#20337DFF"
                                                        CornerRadius="10">
                                                    <TextBlock FontSize="{Binding RoomCardChipFontSize, RelativeSource={RelativeSource AncestorType={x:Type views:MainWindow}}}"
                                                               HorizontalAlignment="Center"
                                                               VerticalAlignment="Center"
                                                               Text="{Binding StreamStatusText}"
                                                               TextAlignment="Center"
                                                               TextTrimming="CharacterEllipsis" />
                                                </Border>
                                                <Border Grid.Column="1"
                                                        Margin="4,0,0,0"
                                                        Height="{Binding RoomCardChipMinHeight, RelativeSource={RelativeSource AncestorType={x:Type views:MainWindow}}}"
                                                        Padding="{Binding RoomCardChipPadding, RelativeSource={RelativeSource AncestorType={x:Type views:MainWindow}}}"
                                                        Background="#2026A269"
                                                        CornerRadius="10">
                                                    <TextBlock FontSize="{Binding RoomCardChipFontSize, RelativeSource={RelativeSource AncestorType={x:Type views:MainWindow}}}"
                                                               HorizontalAlignment="Center"
                                                               VerticalAlignment="Center"
                                                               Text="{Binding RecordStatusText}"
                                                               TextAlignment="Center"
                                                               TextTrimming="CharacterEllipsis" />
                                                </Border>
                                                </ui:Grid>
                                            </ui:Grid>
                                        </Grid>
                                    </Border>
                                    <DataTemplate.Triggers>
                                        <DataTrigger Binding="{Binding IsSelected, RelativeSource={RelativeSource AncestorType={x:Type ListBoxItem}}}" Value="True">
                                            <Setter TargetName="RoomCardShell" Property="Background" Value="#2A4DA7B0" />
                                            <Setter TargetName="RoomCardShell" Property="BorderBrush" Value="#884DA7B0" />
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding AvatarDisplaySource}" Value="">
                                            <Setter TargetName="RoomCardAvatarImage" Property="Visibility" Value="Collapsed" />
                                            <Setter TargetName="RoomCardAvatarPlaceholder" Property="Visibility" Value="Visible" />
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding DataContext.IsCardEditMode, RelativeSource={RelativeSource AncestorType={x:Type ListBox}}}" Value="True">
                                            <DataTrigger.EnterActions>
                                                <BeginStoryboard x:Name="RoomCardWiggleStoryboard">
                                                    <Storyboard AutoReverse="True" RepeatBehavior="Forever">
                                                        <DoubleAnimation Storyboard.TargetName="RoomCardAngle"
                                                                         Storyboard.TargetProperty="Angle"
                                                                         From="-0.45"
                                                                         To="0.45"
                                                                         Duration="0:0:0.12"
                                                                         FillBehavior="Stop" />
                                                    </Storyboard>
                                                </BeginStoryboard>
                                            </DataTrigger.EnterActions>
                                            <DataTrigger.ExitActions>
                                                <StopStoryboard BeginStoryboardName="RoomCardWiggleStoryboard" />
                                            </DataTrigger.ExitActions>
                                        </DataTrigger>
                                    </DataTemplate.Triggers>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                        <ui:StackPanel HorizontalAlignment="Center"
                                       VerticalAlignment="Center"
                                       Opacity="0.8"
                                       Spacing="8"
                                       Visibility="{Binding RoomStatuses.Count, Converter={StaticResource NotZeroIntToToVisibilityConverter}}">
                            <ui:FontIcon FontFamily="{DynamicResource CustomSymbolThemeFontFamily}"
                                         FontSize="40"
                                         Glyph="{x:Static ui:CustomFontSymbols.Empty}" />
                            <TextBlock Text="{I18N EmptyRoomHint}" />
                        </ui:StackPanel>
                    </Grid>
                </Border>
                <ScrollViewer Grid.Column="1"
                              Margin="8,0,0,0"
                              HorizontalScrollBarVisibility="Disabled"
                              VerticalScrollBarVisibility="Auto">
                    <Border MinHeight="520"
                            Padding="18"
                            Background="#0E000000"
                            BorderBrush="{DynamicResource SystemFillColorSolidNeutralBrush}"
                            BorderThickness="1"
                            CornerRadius="8">
                        <ui:StackPanel Spacing="16">
                            <ui:Grid ColumnDefinitions="52,*">
                                <vio:PersonPicture Width="44"
                                                   Height="44"
                                                   HorizontalAlignment="Left"
                                                   VerticalAlignment="Center"
                                                   ProfilePicture="{Binding SelectedItem.AvatarDisplaySource}"
                                                   RenderOptions.BitmapScalingMode="HighQuality"
                                                   SnapsToDevicePixels="True" />
                                <ui:StackPanel Grid.Column="1"
                                               VerticalAlignment="Center"
                                               Spacing="6">
                                    <TextBlock FontSize="20"
                                               FontWeight="SemiBold"
                                               Text="{Binding SelectedItem.NickName}"
                                               TextTrimming="CharacterEllipsis" />
                                    <TextBlock FontSize="12"
                                               Opacity="0.65"
                                               Text="{Binding SelectedItem.UidDisplayText}"
                                               TextTrimming="CharacterEllipsis" />
                                </ui:StackPanel>
                            </ui:Grid>
                            <Separator />
                            <ui:Grid ColumnDefinitions="*,Auto">
                                <TextBlock FontSize="14"
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource SystemAccentColorPrimaryBrush}"
                                           Text="{I18N RoomDetails}" />
                                    <Button Grid.Column="1"
                                        Style="{StaticResource InfoIconButtonStyle}"
                                        Command="{Binding RefreshSelectedRoomInfoCommand}"
                                        ToolTip="{I18N CardRefresh}">
                                    <ui:FontIcon FontFamily="{DynamicResource SymbolThemeFontFamily}"
                                                 FontSize="11"
                                                 Glyph="{x:Static ui:FontSymbols.Sync}"
                                                 RenderTransformOrigin="0.5,0.5">
                                        <ui:FontIcon.RenderTransform>
                                            <RotateTransform />
                                        </ui:FontIcon.RenderTransform>
                                        <ui:FontIcon.Style>
                                            <Style TargetType="{x:Type ui:FontIcon}">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsRefreshingSelectedRoomInfo}" Value="True">
                                                        <DataTrigger.EnterActions>
                                                            <BeginStoryboard x:Name="SelectedRoomInfoRefreshSpin">
                                                                <Storyboard RepeatBehavior="Forever">
                                                                    <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(RotateTransform.Angle)"
                                                                                     From="0"
                                                                                     To="360"
                                                                                     Duration="0:0:0.8" />
                                                                </Storyboard>
                                                            </BeginStoryboard>
                                                        </DataTrigger.EnterActions>
                                                        <DataTrigger.ExitActions>
                                                            <StopStoryboard BeginStoryboardName="SelectedRoomInfoRefreshSpin" />
                                                        </DataTrigger.ExitActions>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </ui:FontIcon.Style>
                                    </ui:FontIcon>
                                </Button>
                            </ui:Grid>
                            <ui:Grid ColumnDefinitions="92,*"
                                     RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto"
                                     Margin="0,-4,0,0">
                                <TextBlock Grid.Row="0"
                                           Opacity="0.62"
                                           Text="{I18N RoomPlatform}" />
                                <ui:StackPanel Grid.Row="0"
                                               Grid.Column="1"
                                               Orientation="Horizontal"
                                               Spacing="6">
                                    <Border Width="16"
                                            Height="16"
                                            CornerRadius="99"
                                            RenderOptions.BitmapScalingMode="HighQuality">
                                        <Border.Background>
                                            <ImageBrush ImageSource="{Binding SelectedItem.PlatformIconSource}" Stretch="UniformToFill" />
                                        </Border.Background>
                                    </Border>
                                    <TextBlock Text="{Binding SelectedItem.PlatformDisplayName}" TextTrimming="CharacterEllipsis" />
                                </ui:StackPanel>
                                <TextBlock Grid.Row="1"
                                           Margin="0,10,0,0"
                                           Opacity="0.62"
                                           Text="{I18N RoomTitle}" />
                                <TextBlock Grid.Row="1"
                                           Grid.Column="1"
                                           Margin="0,10,0,0"
                                           ClipToBounds="True"
                                           MaxHeight="60"
                                           LineHeight="20"
                                           LineStackingStrategy="BlockLineHeight"
                                           Text="{Binding SelectedItem.TitleDisplayText}"
                                           TextTrimming="CharacterEllipsis"
                                           TextWrapping="Wrap"
                                           ToolTip="{Binding SelectedItem.Title}" />
                                <TextBlock Grid.Row="2"
                                           Margin="0,10,0,0"
                                           Opacity="0.62"
                                           Text="{I18N StreamStatus}" />
                                <TextBlock Grid.Row="2"
                                           Grid.Column="1"
                                           Margin="0,10,0,0"
                                           Text="{Binding SelectedItem.StreamStatusText}" />
                                <TextBlock Grid.Row="3"
                                           Margin="0,10,0,0"
                                           Opacity="0.62"
                                           Text="{I18N RecordStatus}" />
                                <TextBlock Grid.Row="3"
                                           Grid.Column="1"
                                           Margin="0,10,0,0"
                                           Text="{Binding SelectedItem.RecordStatusText}" />
                                <TextBlock Grid.Row="4"
                                           Margin="0,10,0,0"
                                           Opacity="0.62"
                                           Text="{I18N RecordFormat}" />
                                <TextBlock Grid.Row="4"
                                           Grid.Column="1"
                                           Margin="0,10,0,0"
                                           Text="{Binding SelectedItem.RecordFormatText}" />
                                <TextBlock Grid.Row="5"
                                           Margin="0,10,0,0"
                                           Opacity="0.62"
                                           Text="{I18N StreamQuality}" />
                                 <TextBlock Grid.Row="5"
                                            Grid.Column="1"
                                            Margin="0,10,0,0"
                                            Text="{Binding SelectedItem.QualityDisplayName}"
                                            TextTrimming="CharacterEllipsis" />
                                <TextBlock Grid.Row="6"
                                           Margin="0,10,0,0"
                                           Opacity="0.62"
                                           Text="{I18N Resolution}" />
                                <TextBlock Grid.Row="6"
                                           Grid.Column="1"
                                           Margin="0,10,0,0"
                                           Text="{Binding SelectedItem.Resolution}"
                                           TextTrimming="CharacterEllipsis" />
                                <TextBlock Grid.Row="7"
                                           Margin="0,10,0,0"
                                           Opacity="0.62"
                                           Text="{I18N Bitrate}" />
                                <TextBlock Grid.Row="7"
                                           Grid.Column="1"
                                           Margin="0,10,0,0"
                                           Text="{Binding SelectedItem.Bitrate}"
                                           TextTrimming="CharacterEllipsis" />
                                <TextBlock Grid.Row="8"
                                           Margin="0,10,0,0"
                                           Opacity="0.62"
                                           Text="{I18N RoomUrl}" />
                                <ui:Grid Grid.Row="8"
                                         Grid.Column="1"
                                         Margin="0,10,0,0"
                                         ColumnDefinitions="*,Auto">
                                     <TextBlock ClipToBounds="True"
                                                MaxHeight="40"
                                                LineHeight="20"
                                                LineStackingStrategy="BlockLineHeight"
                                                Text="{Binding SelectedItem.RoomUrl}"
                                                TextTrimming="CharacterEllipsis"
                                                TextWrapping="Wrap"
                                                ToolTip="{Binding SelectedItem.RoomUrl}" />
                                    <Button Grid.Column="1"
                                            Style="{StaticResource InfoIconButtonStyle}"
                                            Margin="8,0,0,0"
                                            Command="{Binding SelectedItem.CopyRoomUrlCommand}"
                                            ToolTip="{I18N Copy}">
                                        <ui:FontIcon FontFamily="{DynamicResource SymbolThemeFontFamily}" FontSize="11" Glyph="{x:Static ui:FontSymbols.Copy}" />
                                    </Button>
                                </ui:Grid>
                                <TextBlock Grid.Row="9"
                                           Margin="0,10,0,0"
                                           Opacity="0.62"
                                           Text="{I18N LiveStream}" />
                                <ui:Grid Grid.Row="9"
                                         Grid.Column="1"
                                         Margin="0,10,0,0"
                                         ColumnDefinitions="*,Auto">
                                     <TextBlock ClipToBounds="True"
                                                MaxHeight="40"
                                                LineHeight="20"
                                                LineStackingStrategy="BlockLineHeight"
                                                Text="{Binding SelectedItem.LiveStreamDisplayText}"
                                                TextTrimming="CharacterEllipsis"
                                                TextWrapping="Wrap"
                                                ToolTip="{Binding SelectedItem.LiveStreamUrl}" />
                                    <Button Grid.Column="1"
                                            Style="{StaticResource InfoIconButtonStyle}"
                                            Margin="8,0,0,0"
                                            Command="{Binding SelectedItem.CopyLiveStreamCommand}"
                                            ToolTip="{I18N Copy}">
                                        <ui:FontIcon FontFamily="{DynamicResource SymbolThemeFontFamily}" FontSize="11" Glyph="{x:Static ui:FontSymbols.Copy}" />
                                    </Button>
                                </ui:Grid>
                            </ui:Grid>
                            <Separator />
                            <TextBlock FontSize="14"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource SystemAccentColorPrimaryBrush}"
                                       Text="{I18N Operation}" />
                            <WrapPanel>
                                <Button Style="{StaticResource OperationButtonStyle}"
                                        Command="{Binding PreviewCommand}"
                                        ToolTip="{I18N PreviewHint}">
                                    <Button.Content>
                                        <ui:StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Orientation="Horizontal" Spacing="7">
                                            <ui:FontIcon FontFamily="{DynamicResource SymbolThemeFontFamily}" Glyph="{x:Static ui:FontSymbols.Play}" />
                                            <TextBlock Text="{I18N Preview}" />
                                        </ui:StackPanel>
                                    </Button.Content>
                                </Button>
                                <Button Style="{StaticResource OperationButtonStyle}"
                                        Command="{Binding GotoRoomUrlCommand}"
                                        ToolTip="{I18N GotoLiveRoom}">
                                    <Button.Content>
                                        <ui:StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Orientation="Horizontal" Spacing="7">
                                            <ui:FontIcon FontFamily="{DynamicResource SymbolThemeFontFamily}" Glyph="{x:Static ui:FontSymbols.OpenInNewWindow}" />
                                            <TextBlock Text="{I18N ButtonOfGoto}" />
                                        </ui:StackPanel>
                                    </Button.Content>
                                </Button>
                                <Button Style="{StaticResource OperationButtonStyle}"
                                        Command="{Binding ToggleSelectedRoomMonitorCommand}"
                                        ToolTip="{I18N ToolbarMonitor}">
                                    <Button.Content>
                                        <ui:StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Orientation="Horizontal" Spacing="7">
                                            <ui:FontIcon FontFamily="{DynamicResource SymbolThemeFontFamily}" Glyph="{x:Static ui:FontSymbols.Radar}">
                                                <ui:FontIcon.Style>
                                                    <Style TargetType="{x:Type ui:FontIcon}">
                                                        <Setter Property="Foreground" Value="{DynamicResource SystemFillColorSolidNeutralBrush}" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding SelectedItem.EffectiveIsToMonitor}" Value="True">
                                                                <Setter Property="Foreground" Value="{DynamicResource SystemAccentColorPrimaryBrush}" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </ui:FontIcon.Style>
                                            </ui:FontIcon>
                                            <TextBlock Text="{I18N ToolbarMonitor}">
                                                <TextBlock.Style>
                                                    <Style TargetType="{x:Type TextBlock}">
                                                        <Setter Property="Foreground" Value="{DynamicResource TextFillColorSecondaryBrush}" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding SelectedItem.EffectiveIsToMonitor}" Value="True">
                                                                <Setter Property="Foreground" Value="{DynamicResource TextFillColorPrimaryBrush}" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </ui:StackPanel>
                                    </Button.Content>
                                </Button>
                                <Button Style="{StaticResource OperationButtonStyle}"
                                        Command="{Binding ToggleSelectedRoomRecordCommand}"
                                        ToolTip="{I18N ToolbarRecord}">
                                    <Button.Content>
                                        <ui:StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Orientation="Horizontal" Spacing="7">
                                            <ui:FontIcon FontFamily="{DynamicResource SymbolThemeFontFamily}" Glyph="{x:Static ui:FontSymbols.Record}">
                                                <ui:FontIcon.Style>
                                                    <Style TargetType="{x:Type ui:FontIcon}">
                                                        <Setter Property="Foreground" Value="{DynamicResource SystemFillColorSolidNeutralBrush}" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding SelectedItem.EffectiveIsToRecord}" Value="True">
                                                                <Setter Property="Foreground" Value="{DynamicResource SystemAccentColorPrimaryBrush}" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </ui:FontIcon.Style>
                                            </ui:FontIcon>
                                            <TextBlock Text="{I18N ToolbarRecord}">
                                                <TextBlock.Style>
                                                    <Style TargetType="{x:Type TextBlock}">
                                                        <Setter Property="Foreground" Value="{DynamicResource TextFillColorSecondaryBrush}" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding SelectedItem.EffectiveIsToRecord}" Value="True">
                                                                <Setter Property="Foreground" Value="{DynamicResource TextFillColorPrimaryBrush}" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </ui:StackPanel>
                                    </Button.Content>
                                </Button>
                                <ContentControl>
                                    <ContentControl.Style>
                                        <Style TargetType="{x:Type ContentControl}">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding SelectedItem.IsFollowGlobalSettings}" Value="False">
                                                    <Setter Property="Visibility" Value="Visible" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </ContentControl.Style>
                                    <Button Style="{StaticResource OperationButtonStyle}"
                                            Command="{Binding SelectedItem.OpenLocalSettingsCommand}"
                                            ToolTip="{I18N LocalSettings}">
                                        <Button.Content>
                                            <ui:StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Orientation="Horizontal" Spacing="7">
                                                <ui:FontIcon FontFamily="{DynamicResource SymbolThemeFontFamily}" Glyph="{x:Static ui:FontSymbols.Settings}" />
                                                <TextBlock Text="{I18N LocalSettings}" />
                                            </ui:StackPanel>
                                        </Button.Content>
                                    </Button>
                                </ContentControl>
                            </WrapPanel>
                            <UniformGrid Columns="2">
                                <CheckBox Command="{Binding IsToNotifyCommand}"
                                          Margin="0,0,18,0"
                                          Content="{I18N LiveNotification}"
                                          IsChecked="{Binding SelectedItem.IsToNotify, Mode=TwoWay}"
                                          ToolTip="{I18N LiveNotificationHint}" />
                                <CheckBox Command="{Binding IsFollowGlobalSettingsCommand}"
                                          Content="{I18N FollowGlobalSettings}"
                                          IsChecked="{Binding SelectedItem.IsFollowGlobalSettings, Mode=TwoWay}"
                                          ToolTip="{I18N FollowGlobalSettings}" />
                            </UniformGrid>
                        </ui:StackPanel>
                    </Border>
                </ScrollViewer>
            </ui:Grid>
            <ui:Grid Grid.Row="2">
                <ui:StackPanel Margin="0,5,0,0"
                               HorizontalAlignment="Right"
                               Opacity="0.9"
                               Orientation="Horizontal"
                               Spacing="8">
                    <Button Style="{StaticResource StatusIconButtonStyle}"
                            Command="{Binding ToggleMonitorCommand}"
                            ToolTip="{I18N ToolbarMonitor}">
                        <c:If Condition="{Binding StatusOfIsMonitorRunning, Mode=OneWay}">
                            <c:If.TrueValue>
                                <ui:FontIcon FontFamily="{DynamicResource SymbolThemeFontFamily}"
                                             Foreground="{DynamicResource SystemAccentColorPrimaryBrush}"
                                             Glyph="{x:Static ui:FontSymbols.Radar}" />
                            </c:If.TrueValue>
                            <c:If.FalseValue>
                                <ui:FontIcon FontFamily="{DynamicResource SymbolThemeFontFamily}"
                                             Foreground="{DynamicResource SystemFillColorSolidNeutralBrush}"
                                             Glyph="{x:Static ui:FontSymbols.Radar}" />
                            </c:If.FalseValue>
                        </c:If>
                    </Button>
                    <Button Style="{StaticResource StatusIconButtonStyle}"
                            Command="{Binding ToggleNotifyCommand}"
                            ToolTip="{I18N LiveNotification}">
                        <c:If Condition="{Binding StatusOfIsToNotify, Mode=OneWay}">
                            <c:If.TrueValue>
                                <ui:FontIcon FontFamily="{DynamicResource SymbolThemeFontFamily}"
                                             Foreground="{DynamicResource SystemAccentColorPrimaryBrush}"
                                             Glyph="{x:Static ui:FontSymbols.Ringer}" />
                            </c:If.TrueValue>
                            <c:If.FalseValue>
                                <ui:FontIcon FontFamily="{DynamicResource SymbolThemeFontFamily}"
                                             Foreground="{DynamicResource SystemFillColorSolidNeutralBrush}"
                                             Glyph="{x:Static ui:FontSymbols.Ringer}" />
                            </c:If.FalseValue>
                        </c:If>
                    </Button>
                    <Button Style="{StaticResource StatusIconButtonStyle}"
                            Command="{Binding ToggleRecordCommand}"
                            ToolTip="{I18N EnableRecord}">
                        <c:If Condition="{Binding StatusOfIsToRecord, Mode=OneWay}">
                            <c:If.TrueValue>
                                <ui:FontIcon FontFamily="{DynamicResource SymbolThemeFontFamily}"
                                             Foreground="{DynamicResource SystemAccentColorPrimaryBrush}"
                                             Glyph="{x:Static ui:FontSymbols.Video}" />
                            </c:If.TrueValue>
                            <c:If.FalseValue>
                                <ui:FontIcon FontFamily="{DynamicResource SymbolThemeFontFamily}"
                                             Foreground="{DynamicResource SystemFillColorSolidNeutralBrush}"
                                             Glyph="{x:Static ui:FontSymbols.Video}" />
                            </c:If.FalseValue>
                        </c:If>
                    </Button>
                    <Button Style="{StaticResource StatusIconButtonStyle}"
                            Command="{Binding ToggleProxyCommand}"
                            ToolTip="{I18N UseProxy}">
                        <c:If Condition="{Binding StatusOfIsUseProxy, Mode=OneWay}">
                            <c:If.TrueValue>
                                <ui:FontIcon FontFamily="{DynamicResource SymbolThemeFontFamily}"
                                             Foreground="{DynamicResource SystemAccentColorPrimaryBrush}"
                                             Glyph="{x:Static ui:FontSymbols.VPN}" />
                            </c:If.TrueValue>
                            <c:If.FalseValue>
                                <ui:FontIcon FontFamily="{DynamicResource SymbolThemeFontFamily}"
                                             Foreground="{DynamicResource SystemFillColorSolidNeutralBrush}"
                                             Glyph="{x:Static ui:FontSymbols.VPN}" />
                            </c:If.FalseValue>
                        </c:If>
                    </Button>
                    <Button Style="{StaticResource StatusIconButtonStyle}"
                            Command="{Binding ToggleKeepAwakeCommand}"
                            ToolTip="{I18N KeepAwake}">
                        <c:If Condition="{Binding StatusOfIsUseKeepAwake, Mode=OneWay}">
                            <c:If.TrueValue>
                                <ui:FontIcon FontFamily="{DynamicResource SymbolThemeFontFamily}"
                                             Foreground="{DynamicResource SystemAccentColorPrimaryBrush}"
                                             Glyph="{x:Static ui:FontSymbols.Recent}" />
                            </c:If.TrueValue>
                            <c:If.FalseValue>
                                <ui:FontIcon FontFamily="{DynamicResource SymbolThemeFontFamily}"
                                             Foreground="{DynamicResource SystemFillColorSolidNeutralBrush}"
                                             Glyph="{x:Static ui:FontSymbols.Recent}" />
                            </c:If.FalseValue>
                        </c:If>
                    </Button>
                    <Button Style="{StaticResource StatusIconButtonStyle}"
                            Command="{Binding ToggleAutoShutdownCommand}"
                            ToolTip="{I18N AutoShutdown}">
                        <c:If Condition="{Binding StatusOfIsUseAutoShutdown, Mode=OneWay}">
                            <c:If.TrueValue>
                                <ui:FontIcon FontFamily="{DynamicResource SymbolThemeFontFamily}"
                                             Foreground="{DynamicResource SystemAccentColorPrimaryBrush}"
                                             Glyph="{x:Static ui:FontSymbols.PowerButton}" />
                            </c:If.TrueValue>
                            <c:If.FalseValue>
                                <ui:FontIcon FontFamily="{DynamicResource SymbolThemeFontFamily}"
                                             Foreground="{DynamicResource SystemFillColorSolidNeutralBrush}"
                                             Glyph="{x:Static ui:FontSymbols.PowerButton}" />
                            </c:If.FalseValue>
                        </c:If>
                    </Button>
                    <TextBlock FontSize="12"
                               Foreground="{DynamicResource SystemAccentColorPrimaryBrush}"
                               Text="{Binding StatusOfAutoShutdownTime}"
                               ToolTip="{I18N AutoShutdown}"
                               Visibility="{Binding StatusOfIsUseAutoShutdown, Converter={x:Static c:BoolToVisibilityConverter.Instance}}" />
                    <Separator />
                    <Button x:Name="RoutineIntervalStatusButton"
                            Style="{StaticResource MainFlyoutTextButtonStyle}"
                            Click="RoutineIntervalStatusButtonClick"
                            ToolTip="{I18N RoutineInterval}">
                        <ui:StackPanel Orientation="Horizontal" Spacing="4">
                            <TextBlock FontSize="12"
                                       Opacity="0.85"
                                       Text="{Binding StatusOfRoutineIntervalWithUnit}" />
                            <ui:FontIcon FontFamily="{DynamicResource SymbolThemeFontFamily}"
                                         FontSize="10"
                                         Glyph="{x:Static ui:FontSymbols.ChevronDown}" />
                        </ui:StackPanel>
                    </Button>
                    <Separator />
                    <TextBlock x:Name="RecordFormatStatusText"
                               VerticalAlignment="Center"
                               FontSize="12"
                               Opacity="0.6"
                               Cursor="Hand"
                               MouseLeftButtonDown="RecordFormatStatusTextMouseLeftButtonDown"
                               Text="{Binding StatusOfRecordFormat}"
                               ToolTip="{I18N RecordFormat}" />
                </ui:StackPanel>
            </ui:Grid>
        </ui:Grid>
        <Canvas x:Name="MainFlyoutLayer"
                Margin="8,42,8,8"
                ClipToBounds="True"
                Panel.ZIndex="50">
            <Border x:Name="RoutineIntervalFlyout"
                    Width="270"
                    Padding="14"
                    Style="{StaticResource MainFlyoutBorderStyle}"
                    Visibility="Collapsed">
                <ui:Grid RowDefinitions="Auto,Auto">
                    <TextBlock Grid.Row="0"
                               Margin="2,0,0,10"
                               FontWeight="SemiBold"
                               Text="{I18N RoutineInterval}" />
                    <ui:Grid Grid.Row="1" ColumnDefinitions="*,90,34">
                        <ui:TextBox x:Name="RoutineIntervalInput"
                                    MinWidth="112"
                                    Margin="0,0,8,0" />
                        <ComboBox x:Name="RoutineIntervalUnitComboBox"
                                  Grid.Column="1"
                                  MinWidth="82"
                                  Margin="0,0,8,0"
                                  SelectionChanged="RoutineIntervalUnitSelectionChanged">
                            <ComboBoxItem Content="{Binding RoutineIntervalSecondsText, ElementName=Root}" />
                            <ComboBoxItem Content="{Binding RoutineIntervalMinutesText, ElementName=Root}" />
                        </ComboBox>
                        <Button Grid.Column="2"
                                Width="32"
                                Height="32"
                                MinWidth="32"
                                Padding="0"
                                Background="{DynamicResource SystemAccentColorPrimaryBrush}"
                                BorderBrush="{DynamicResource SystemAccentColorPrimaryBrush}"
                                Foreground="White"
                                Click="RoutineIntervalConfirmClick">
                            <ui:FontIcon FontFamily="{DynamicResource SymbolThemeFontFamily}"
                                         FontSize="12"
                                         Glyph="{x:Static ui:FontSymbols.Accept}" />
                        </Button>
                    </ui:Grid>
                </ui:Grid>
            </Border>
            <Border x:Name="RecordFormatFlyout"
                    MinWidth="170"
                    Padding="8"
                    Style="{StaticResource MainFlyoutBorderStyle}"
                    Visibility="Collapsed">
                <ui:StackPanel Spacing="4">
                    <Button Content="TS/FLV" Tag="TS/FLV" Click="RecordFormatOptionClick" Style="{StaticResource MainFlyoutOptionButtonStyle}" />
                    <Button Content="TS/FLV -> MP4" Tag="TS/FLV -> MP4" Click="RecordFormatOptionClick" Style="{StaticResource MainFlyoutOptionButtonStyle}" />
                    <Button Content="TS/FLV -> MKV" Tag="TS/FLV -> MKV" Click="RecordFormatOptionClick" Style="{StaticResource MainFlyoutOptionButtonStyle}" />
                </ui:StackPanel>
            </Border>
            <Border x:Name="AddRoomFlyout"
                    Width="540"
                    Padding="18"
                    Style="{StaticResource MainFlyoutBorderStyle}"
                    Visibility="Collapsed">
                <ui:Grid RowDefinitions="Auto,Auto,Auto">
                    <ui:Grid Grid.Row="0" ColumnDefinitions="Auto,*">
                        <ui:FontIcon Grid.Column="0"
                                     Margin="0,0,12,0"
                                     VerticalAlignment="Center"
                                     FontFamily="{DynamicResource SymbolThemeFontFamily}"
                                     FontSize="20"
                                     Glyph="{x:Static ui:FontSymbols.Add}" />
                        <TextBlock Grid.Column="1"
                                   Style="{StaticResource MainFlyoutTitleStyle}"
                                   Text="{I18N AddRoom}" />
                    </ui:Grid>
                    <ui:StackPanel Grid.Row="1"
                                   Margin="0,16,0,16"
                                   Spacing="10">
                        <TextBlock Style="{StaticResource MainFlyoutCaptionStyle}" Text="{I18N EnterRoomUrl}" />
                        <ui:TextBox x:Name="AddRoomUrlInput" PlaceholderText="https://live.douyin.com/xxx" />
                        <CheckBox x:Name="AddRoomForceCheckBox" Content="{I18N AddRoomForce}" />
                    </ui:StackPanel>
                    <ui:StackPanel Grid.Row="2"
                                   HorizontalAlignment="Right"
                                   Orientation="Horizontal"
                                   Spacing="8">
                        <Button MinWidth="78"
                                Background="{DynamicResource ControlFillColorDefaultBrush}"
                                BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
                                Content="{I18N ButtonOfClose}"
                                Click="CloseFloatingPanelsClick" />
                        <Button MinWidth="78"
                                Background="{DynamicResource SystemAccentColorPrimaryBrush}"
                                BorderBrush="{DynamicResource SystemAccentColorPrimaryBrush}"
                                Foreground="White"
                                Content="{I18N ButtonOfAdd}"
                                Click="AddRoomConfirmClick" />
                    </ui:StackPanel>
                </ui:Grid>
            </Border>
            <Border x:Name="AboutFlyout"
                    Width="540"
                    Padding="18"
                    Style="{StaticResource MainFlyoutBorderStyle}"
                    Visibility="Collapsed">
                <ui:Grid RowDefinitions="Auto,Auto,Auto">
                    <ui:Grid Grid.Row="0" ColumnDefinitions="Auto,*,Auto">
                        <Image Grid.Column="0"
                               Height="44"
                               Source="pack://application:,,,/Assets/Favicon.png" />
                        <ui:StackPanel Grid.Column="1"
                                       Margin="12,0,0,0"
                                       VerticalAlignment="Center"
                                       Spacing="3">
                            <TextBlock Style="{StaticResource MainFlyoutTitleStyle}" Text="{x:Static local:AppConfig.DisplayName}" />
                            <TextBlock Style="{StaticResource MainFlyoutCaptionStyle}" Text="{x:Static local:AppConfig.EnglishName}" />
                            <TextBlock Style="{StaticResource MainFlyoutCaptionStyle}" Text="{x:Static local:AppConfig.Version}" />
                        </ui:StackPanel>
